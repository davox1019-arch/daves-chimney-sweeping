---
const {
  title = "Daves Chimney Sweeping",
  description = "Local chimney sweeping, flue cleaning and wood heater cleaning in Melbourne.",
  clusterBase = "Melbourne",
  clusterRegion = "Melbourne and surrounding suburbs",
  servicePageHref = "/chimney-sweeping",
  servicePageLabel = "Chimney Sweeping",
  homeHref = "/",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      :root {
        --bg: #f5efe7;
        --bg-soft: #fbf8f4;
        --text: #171717;
        --muted: #666;
        --card: rgba(255, 255, 255, 0.94);
        --accent: #151515;
        --accent-2: #b98134;
        --accent-3: #f4e2c4;
        --border: #e5dbcf;
        --max-width: 1160px;
        --radius: 24px;
        --shadow: 0 18px 48px rgba(0, 0, 0, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(255, 239, 214, 0.9) 0%, transparent 30%),
          linear-gradient(180deg, #f8f3ed 0%, #f1ebe4 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 20px;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 200;
        backdrop-filter: blur(10px);
        background: rgba(255, 250, 245, 0.88);
        border-bottom: 1px solid rgba(229, 219, 207, 0.95);
      }

      .header-inner {
        min-height: 110px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
        flex: 1;
      }

      .brand-logo {
        width: 150px;
        height: 150px;
        object-fit: contain;
        flex: 0 0 72px;
        filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.18));
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
      }

      .brand-name {
        font-size: 50px;
        font-weight: 800;
        line-height: 1.02;
        letter-spacing: -0.03em;
      }

      .brand-sub {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.3;
      }

      .desktop-nav {
        display: flex;
        align-items: center;
        gap: 18px;
      }

      .desktop-nav a {
        font-size: 15px;
        font-weight: 700;
      }

      .phone-btn {
        display: inline-block;
        background: linear-gradient(135deg, #111 0%, #2c2c2c 100%);
        color: white;
        padding: 12px 18px;
        border-radius: 999px;
        font-weight: 800;
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.16);
      }

      .menu-toggle {
        display: none;
        width: 52px;
        height: 52px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.95);
        border-radius: 14px;
        padding: 0;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
      }

      .menu-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: #111;
        border-radius: 999px;
        position: relative;
      }

      .menu-toggle span::before,
      .menu-toggle span::after {
        content: "";
        position: absolute;
        left: 0;
        width: 22px;
        height: 2px;
        background: #111;
        border-radius: 999px;
      }

      .menu-toggle span::before {
        top: -7px;
      }

      .menu-toggle span::after {
        top: 7px;
      }

      .mobile-menu {
        display: none;
        padding: 0 0 16px;
      }

      .mobile-menu.open {
        display: block;
      }

      .mobile-menu-card {
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.96);
        border-radius: 18px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .mobile-menu-card a {
        display: block;
        padding: 16px 18px;
        font-weight: 700;
        border-top: 1px solid var(--border);
      }

      .mobile-menu-card a:first-child {
        border-top: none;
      }

      .mobile-call {
        background: linear-gradient(135deg, #111 0%, #2b2b2b 100%);
        color: white !important;
      }

      main {
        padding: 34px 0 56px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(185, 129, 52, 0.14) 0%, rgba(255, 255, 255, 0) 46%),
          linear-gradient(180deg, #ffffff 0%, #faf6f1 100%);
        border: 1px solid var(--border);
        border-radius: 30px;
        box-shadow: var(--shadow);
        padding: 56px;
      }

      .hero::before {
        content: "";
        position: absolute;
        right: -90px;
        top: -90px;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(185, 129, 52, 0.18) 0%, rgba(185, 129, 52, 0) 70%);
        pointer-events: none;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: var(--accent-3);
        border: 1px solid rgba(185, 129, 52, 0.3);
        color: #6d4b18;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 18px;
      }

      .hero h1 {
        margin: 0 0 14px;
        font-size: 54px;
        line-height: 0.98;
        letter-spacing: -0.04em;
        max-width: 760px;
      }

      .hero p {
        margin: 0 0 14px;
        max-width: 760px;
        font-size: 18px;
        line-height: 1.78;
        color: #353535;
      }

      .button-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .btn {
        display: inline-block;
        padding: 14px 20px;
        border-radius: 14px;
        font-weight: 800;
        transition: transform 0.15s ease;
      }

      .btn:hover {
        transform: translateY(-1px);
      }

      .btn-primary {
        color: white;
        background: linear-gradient(135deg, #111 0%, #2b2b2b 100%);
        box-shadow: 0 12px 26px rgba(0, 0, 0, 0.15);
      }

      .btn-secondary {
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid var(--border);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
        margin-top: 24px;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: var(--shadow);
        padding: 32px;
        margin-top: 24px;
      }

      .card h2 {
        margin: 0 0 14px;
        font-size: 31px;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      .card h3 {
        margin: 20px 0 10px;
        font-size: 21px;
      }

      .card p,
      .card li {
        font-size: 17px;
        line-height: 1.82;
        color: #313131;
      }

      .card ul {
        padding-left: 22px;
        margin: 0;
      }

      .card a {
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(185, 129, 52, 0.55);
      }

      .site-footer {
        margin-top: 56px;
        background: linear-gradient(180deg, #1a1a1a 0%, #111 100%);
        color: white;
      }

      .footer-inner {
        padding: 38px 20px;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 24px;
      }

      .footer-title {
        margin: 0 0 12px;
        font-size: 20px;
      }

      .footer-text,
      .footer-links a {
        color: rgba(255, 255, 255, 0.86);
        font-size: 15px;
        line-height: 1.8;
      }

      .footer-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .footer-bottom {
        margin-top: 24px;
        padding-top: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        font-size: 14px;
        color: rgba(255, 255, 255, 0.72);
      }

      @media (max-width: 900px) {
        .grid,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .hero h1 {
          font-size: 40px;
        }
      }

      @media (max-width: 760px) {
        .container {
          padding: 0 14px;
        }

        .header-inner {
          min-height: 100px;
          gap: 10px;
        }

        .desktop-nav {
          display: none;
        }

        .menu-toggle {
          display: inline-flex;
        }

        .brand {
          gap: 10px;
          min-width: 0;
        }

        .brand-logo {
          width: 99px;
          height: 99px;
          flex-basis: 58px;
        }

        .brand-name {
          font-size: 49px;
        }

        .brand-sub {
          display: none;
        }

        .hero,
        .card {
          padding: 22px;
          border-radius: 18px;
        }

        .hero h1 {
          font-size: 31px;
        }

        .hero p,
        .card p,
        .card li {
          font-size: 16px;
        }

        .card h2 {
          font-size: 24px;
        }

        .card h3 {
          font-size: 19px;
        }

        .btn {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <div class="header-inner">
          <a class="brand" href={homeHref}>
            <img class="brand-logo" src="/daves-logo.png?v=2" alt="Daves Chimney Sweeping logo" />

            <span class="brand-text">
              <span class="brand-name">Daves Chimney Sweeping</span>
              <span class="brand-sub">Based in {clusterBase} • Servicing {clusterRegion}</span>
            </span>
          </a>

          <nav class="desktop-nav">
            <a href={homeHref}>Home</a>
            <a href={servicePageHref}>{servicePageLabel}</a>
            <a href="/contact">Contact</a>
            <a class="phone-btn" href="tel:0476302729">0476 302 729</a>
          </nav>

          <button class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
            <span></span>
          </button>
        </div>

        <div id="mobile-menu" class="mobile-menu">
          <div class="mobile-menu-card">
            <a href={homeHref}>Home</a>
            <a href={servicePageHref}>{servicePageLabel}</a>
            <a href="/contact">Contact</a>
            <a class="mobile-call" href="tel:0476302729">Call 0476 302 729</a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-grid">
          <div>
            <h3 class="footer-title">Daves Chimney Sweeping</h3>
            <div class="footer-text">
              Local chimney sweeping, flue cleaning and wood heater cleaning.
              Based in {clusterBase} and servicing {clusterRegion}.
            </div>
          </div>

          <div>
            <h3 class="footer-title">Our Services</h3>
            <div class="footer-links">
              <a href={servicePageHref}>{servicePageLabel}</a>
              <a href="/contact">Request a Quote</a>
            </div>
          </div>

          <div>
            <h3 class="footer-title">Contact</h3>
            <div class="footer-links">
              <a href="tel:0476302729">0476 302 729</a>
              <a href="/contact">Contact Page</a>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          © 2026 Daves Chimney Sweeping. All rights reserved.
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.querySelector('.menu-toggle');
      const menu = document.querySelector('#mobile-menu');

      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          const open = menu.classList.toggle('open');
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      }
    </script>
  </body>
</html>