---
const {
  title = "Daves Chimney Sweeping",
  description = "Local chimney sweeping, flue cleaning and wood heater cleaning in Melbourne.",
  clusterBase = "Melbourne",
  clusterRegion = "Melbourne and surrounding suburbs",
  servicePageHref = "/chimney-sweeping",
  servicePageLabel = "Chimney Sweeping",
  homeHref = "/",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      :root {
        --bg: #f6f3ee;
        --bg-soft: #fcfaf7;
        --text: #171717;
        --muted: #666;
        --card: #ffffff;
        --accent: #111111;
        --accent-hover: #2b2b2b;
        --border: #e8e0d6;
        --gold: #b7863b;
        --gold-soft: #f5e7cf;
        --max-width: 1140px;
        --radius: 18px;
        --shadow: 0 14px 40px rgba(0, 0, 0, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background:
          radial-gradient(circle at top left, #fff7ea 0%, transparent 28%),
          linear-gradient(180deg, #f7f3ed 0%, #f3efe8 100%);
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 20px;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(10px);
        background: rgba(255, 252, 247, 0.88);
        border-bottom: 1px solid rgba(232, 224, 214, 0.9);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        min-height: 84px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .logo-mark {
        width: 52px;
        height: 52px;
        flex: 0 0 52px;
        border-radius: 14px;
        background: linear-gradient(135deg, #1d1d1d 0%, #333 100%);
        display: grid;
        place-items: center;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
      }

      .logo-mark svg {
        width: 30px;
        height: 30px;
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .brand-name {
        font-size: 24px;
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.02em;
      }

      .brand-sub {
        font-size: 14px;
        color: var(--muted);
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
      }

      .nav a {
        font-size: 15px;
        font-weight: 700;
        color: #2a2a2a;
      }

      .nav a:hover {
        color: #000;
      }

      .phone-btn {
        display: inline-block;
        background: linear-gradient(135deg, #111 0%, #2a2a2a 100%);
        color: white;
        padding: 12px 17px;
        border-radius: 999px;
        font-weight: 800;
        white-space: nowrap;
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.16);
      }

      .phone-btn:hover {
        background: linear-gradient(135deg, #222 0%, #3a3a3a 100%);
      }

      main {
        padding: 34px 0 56px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(183, 134, 59, 0.12) 0%, rgba(255,255,255,0) 45%),
          linear-gradient(180deg, #ffffff 0%, #fbf8f4 100%);
        border: 1px solid var(--border);
        border-radius: 26px;
        box-shadow: var(--shadow);
        padding: 52px;
      }

      .hero::after {
        content: "";
        position: absolute;
        right: -80px;
        top: -80px;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(183,134,59,0.16) 0%, rgba(183,134,59,0) 70%);
        pointer-events: none;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--gold-soft);
        color: #6b4a18;
        border: 1px solid rgba(183, 134, 59, 0.24);
        border-radius: 999px;
        padding: 8px 13px;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 18px;
      }

      .hero h1 {
        margin: 0 0 14px;
        font-size: 50px;
        line-height: 1.02;
        letter-spacing: -0.03em;
        max-width: 760px;
      }

      .hero p {
        margin: 0 0 14px;
        font-size: 18px;
        line-height: 1.75;
        color: #343434;
        max-width: 760px;
      }

      .button-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .btn {
        display: inline-block;
        padding: 14px 20px;
        border-radius: 14px;
        font-weight: 800;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }

      .btn:hover {
        transform: translateY(-1px);
      }

      .btn-primary {
        background: linear-gradient(135deg, #111 0%, #2a2a2a 100%);
        color: white;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
      }

      .btn-secondary {
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid var(--border);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px;
        margin-top: 24px;
      }

      .card {
        background: rgba(255,255,255,0.92);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: var(--shadow);
        padding: 30px;
        margin-top: 24px;
      }

      .card h2 {
        margin: 0 0 14px;
        font-size: 30px;
        line-height: 1.12;
        letter-spacing: -0.02em;
      }

      .card h3 {
        margin: 20px 0 10px;
        font-size: 21px;
      }

      .card p,
      .card li {
        font-size: 17px;
        line-height: 1.8;
        color: #313131;
      }

      .card ul {
        padding-left: 22px;
        margin: 0;
      }

      .card a {
        text-decoration: underline;
        text-decoration-color: rgba(183, 134, 59, 0.55);
        text-underline-offset: 3px;
      }

      .site-footer {
        margin-top: 56px;
        background:
          linear-gradient(180deg, #1a1a1a 0%, #111 100%);
        color: white;
      }

      .footer-inner {
        padding: 38px 20px;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: 24px;
      }

      .footer-title {
        margin: 0 0 12px;
        font-size: 20px;
      }

      .footer-text,
      .footer-links a {
        color: rgba(255, 255, 255, 0.86);
        font-size: 15px;
        line-height: 1.8;
      }

      .footer-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .footer-bottom {
        margin-top: 24px;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,0.12);
        font-size: 14px;
        color: rgba(255,255,255,0.72);
      }

      @media (max-width: 900px) {
        .header-inner {
          align-items: flex-start;
          flex-direction: column;
          padding: 16px 0;
        }

        .nav {
          width: 100%;
        }

        .grid,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .hero h1 {
          font-size: 38px;
        }
      }

      @media (max-width: 700px) {
        .container {
          padding: 0 14px;
        }

        .hero,
        .card {
          padding: 22px;
          border-radius: 18px;
        }

        .hero h1 {
          font-size: 31px;
        }

        .hero p,
        .card p,
        .card li {
          font-size: 16px;
        }

        .card h2 {
          font-size: 24px;
        }

        .card h3 {
          font-size: 19px;
        }

        .btn,
        .phone-btn {
          width: 100%;
          text-align: center;
        }

        .nav {
          flex-direction: column;
          align-items: stretch;
        }

        .brand-name {
          font-size: 21px;
        }

        .logo-mark {
          width: 46px;
          height: 46px;
          flex-basis: 46px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={homeHref}>
          <span class="logo-mark" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 44V28C20 21.3726 25.3726 16 32 16C38.6274 16 44 21.3726 44 28V44" stroke="#E8C58B" stroke-width="5" stroke-linecap="round"/>
              <path d="M24 44H40" stroke="#ffffff" stroke-width="5" stroke-linecap="round"/>
              <path d="M32 10V18" stroke="#ffffff" stroke-width="5" stroke-linecap="round"/>
              <path d="M26 8L29 13" stroke="#ffffff" stroke-width="4" stroke-linecap="round"/>
              <path d="M38 8L35 13" stroke="#ffffff" stroke-width="4" stroke-linecap="round"/>
            </svg>
          </span>

          <span class="brand-text">
            <span class="brand-name">Daves Chimney Sweeping</span>
            <span class="brand-sub">Based in {clusterBase} • Servicing {clusterRegion}</span>
          </span>
        </a>

        <nav class="nav">
          <a href={homeHref}>Home</a>
          <a href={servicePageHref}>{servicePageLabel}</a>
          <a href="/contact">Contact</a>
          <a class="phone-btn" href="tel:0476302729">0476 302 729</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-grid">
          <div>
            <h3 class="footer-title">Daves Chimney Sweeping</h3>
            <div class="footer-text">
              Local chimney sweeping, flue cleaning and wood heater cleaning.
              Based in {clusterBase} and servicing {clusterRegion}.
            </div>
          </div>

          <div>
            <h3 class="footer-title">Our Services</h3>
            <div class="footer-links">
              <a href={servicePageHref}>{servicePageLabel}</a>
              <a href="/contact">Request a Quote</a>
            </div>
          </div>

          <div>
            <h3 class="footer-title">Contact</h3>
            <div class="footer-links">
              <a href="tel:0476302729">0476 302 729</a>
              <a href="/contact">Contact Page</a>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          © 2026 Daves Chimney Sweeping. All rights reserved.
        </div>
      </div>
    </footer>
  </body>
</html>