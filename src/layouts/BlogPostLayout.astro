---
import MainLayout from "./MainLayout.astro";

interface Props {
  title: string;
  description: string;
  publishDate: string;
  readTime: string;
}

const { title, description, publishDate, readTime } = Astro.props;
---

<MainLayout title={title} description={description} suppressAbout={true}>
  <style>
    .blog-hero {
      background: linear-gradient(160deg, #2c1a0c 0%, #18120a 100%);
      color: white;
      padding: 56px 20px 48px;
      border-bottom: 3px solid #c8500a;
    }

    .blog-hero-inner {
      max-width: 780px;
      margin: 0 auto;
    }

    .blog-label {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #c8500a;
      margin-bottom: 14px;
    }

    .blog-hero h1 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      margin: 0 0 16px;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    .blog-meta {
      font-size: 0.88rem;
      color: rgba(255,255,255,0.55);
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }

    .blog-body {
      max-width: 780px;
      margin: 0 auto;
      padding: 52px 20px 0;
    }

    .blog-body h2 {
      font-size: 1.45rem;
      font-weight: 800;
      margin: 2.2rem 0 0.8rem;
      color: #171717;
      letter-spacing: -0.01em;
    }

    .blog-body h3 {
      font-size: 1.15rem;
      font-weight: 700;
      margin: 1.6rem 0 0.6rem;
      color: #2c1a0c;
    }

    .blog-body p {
      font-size: 1.06rem;
      line-height: 1.85;
      color: #333;
      margin: 0 0 1.2rem;
    }

    .blog-body ul, .blog-body ol {
      padding-left: 1.4rem;
      margin: 0 0 1.2rem;
    }

    .blog-body li {
      font-size: 1.06rem;
      line-height: 1.85;
      color: #333;
      margin-bottom: 0.4rem;
    }

    .blog-body strong {
      font-weight: 700;
      color: #171717;
    }

    .callout {
      background: rgba(200, 80, 10, 0.08);
      border-left: 4px solid #c8500a;
      border-radius: 0 12px 12px 0;
      padding: 18px 20px;
      margin: 1.6rem 0;
    }

    .callout p {
      margin: 0;
      font-weight: 600;
      color: #2c1a0c;
    }

    .blog-cta {
      background: linear-gradient(135deg, #2c1a0c, #1a1a18);
      color: white;
      border-radius: 20px;
      padding: 36px 32px;
      margin: 48px 0 0;
      text-align: center;
    }

    .blog-cta h3 {
      font-size: 1.5rem;
      font-weight: 800;
      margin: 0 0 10px;
      color: white;
    }

    .blog-cta p {
      color: rgba(255,255,255,0.78);
      margin: 0 0 22px;
      font-size: 1rem;
    }

    .cta-buttons {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-block;
      background: #c8500a;
      color: white;
      font-weight: 800;
      font-size: 1rem;
      padding: 14px 28px;
      border-radius: 12px;
      text-decoration: none;
      transition: background 0.15s;
    }

    .btn-primary:hover { background: #a84008; }

    .btn-secondary {
      display: inline-block;
      background: rgba(255,255,255,0.12);
      color: white;
      font-weight: 700;
      font-size: 1rem;
      padding: 14px 28px;
      border-radius: 12px;
      text-decoration: none;
      transition: background 0.15s;
    }

    .btn-secondary:hover { background: rgba(255,255,255,0.2); }

    .back-to-blog {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.9rem;
      font-weight: 700;
      color: #c8500a;
      margin-bottom: 32px;
      text-decoration: none;
    }

    .back-to-blog:hover { color: #a84008; }

    /* Booking form */
    .blog-form-section {
      max-width: 780px;
      margin: 0 auto;
      padding: 52px 20px 0;
      border-top: 1px solid #e2ddd4;
      margin-top: 52px;
    }

    .blog-form-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #c8500a;
      margin-bottom: 0.55rem;
      display: block;
    }

    .blog-form-section h2 {
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #1a1a18;
      margin: 0 0 1rem;
      line-height: 1.2;
    }

    .form-wrap {
      background: #f5f0e8;
      border: 2px solid #c8500a;
      border-radius: 10px;
      padding: 1.75rem 1.25rem;
      margin-top: 1rem;
    }

    .form-wrap h3 {
      font-size: 1.15rem;
      font-weight: 800;
      color: #1a1a18;
      margin: 0 0 0.25rem;
    }

    .form-sub {
      font-size: 0.9rem;
      color: #5a5a54;
      margin: 0 0 1.25rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.7rem;
    }

    @media (max-width: 500px) { .form-grid { grid-template-columns: 1fr; } }

    .field { display: flex; flex-direction: column; gap: 0.3rem; }
    .field.full { grid-column: 1 / -1; }

    .field label {
      font-size: 0.8rem;
      font-weight: 700;
      color: #1a1a18;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .field input, .field select, .field textarea {
      width: 100%;
      box-sizing: border-box;
      border: 2px solid #e2ddd4;
      border-radius: 8px;
      padding: 0.72rem 0.85rem;
      font-size: 1rem;
      background: #fff;
      color: #1a1a18;
      font-family: inherit;
      transition: border-color 0.15s;
      outline: none;
    }

    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: #c8500a;
    }

    .field textarea { resize: vertical; min-height: 90px; }

    .form-submit {
      display: block;
      width: 100%;
      margin-top: 1rem;
      background: #c8500a;
      color: #fff;
      border: none;
      padding: 1rem;
      border-radius: 10px;
      font-size: 1.05rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s, transform 0.15s;
    }

    .form-submit:hover { opacity: 0.88; transform: translateY(-1px); }

    /* Bottom spacer */
    .blog-bottom-pad { padding-bottom: 72px; max-width: 780px; margin: 0 auto; }

    /* Sticky CTA */
    #blog-sticky-cta {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      z-index: 999;
      display: flex;
      align-items: center;
      gap: 0.55rem;
      background: #c8500a;
      color: #fff;
      padding: 0.75rem 1.2rem 0.75rem 1rem;
      border-radius: 50px;
      font-size: 0.95rem;
      font-weight: 800;
      letter-spacing: 0.02em;
      text-decoration: none;
      box-shadow: 0 4px 18px rgba(0,0,0,0.35);
      transition: opacity 0.2s, transform 0.2s;
      opacity: 0;
      pointer-events: none;
    }

    #blog-sticky-cta.visible { opacity: 1; pointer-events: auto; }
    #blog-sticky-cta:hover { opacity: 0.9; transform: translateY(-2px); }
    #blog-sticky-icon { font-size: 1.1rem; line-height: 1; }
  </style>

  <div class="blog-hero">
    <div class="blog-hero-inner">
      <span class="blog-label">Dave's Chimney Blog</span>
      <h1>{title}</h1>
      <div class="blog-meta">
        <span>{publishDate}</span>
        <span>{readTime} read</span>
      </div>
    </div>
  </div>

  <div class="blog-body">
    <a href="/blog" class="back-to-blog">← All articles</a>
    <slot />
    <div class="blog-cta">
      <h3>Ready to book a chimney sweep?</h3>
      <p>Flue &amp; wood heater from $199 — masonry/brick from $299. Full clean and inspection, no call-out fee. Serving all Melbourne suburbs.</p>
      <div class="cta-buttons">
        <a href="tel:0476302729" class="btn-primary">📞 Call 0476 302 729</a>
        <a href="#quote" class="btn-secondary">Get a Quote</a>
      </div>
    </div>
  </div>

  <section class="blog-form-section" id="quote">
    <span class="blog-form-label">Book now</span>
    <h2>Book Your Chimney Clean — Melbourne</h2>
    <div class="form-wrap">
      <h3>Quick Quote</h3>
      <p class="form-sub">Fill in your details and Dave will get back to you to confirm your booking. Flue &amp; wood heater $199 — masonry/brick chimney $299.</p>
      <form action="https://formspree.io/f/maqlwkpr" method="POST">
        <input type="hidden" name="suburb" value="Melbourne VIC" />
        <input type="hidden" name="source" value="blog" />
        <div class="form-grid">
          <div class="field"><label>Full Name</label><input type="text" name="name" required placeholder="Your name" /></div>
          <div class="field"><label>Phone Number</label><input type="tel" name="phone" required placeholder="0400 000 000" /></div>
          <div class="field"><label>Email Address</label><input type="email" name="email" placeholder="Optional" /></div>
          <div class="field"><label>Your Suburb</label><input type="text" name="suburb_detail" placeholder="e.g. Kew, Eltham, Werribee…" /></div>
          <div class="field"><label>Service Needed</label>
            <select name="service" required>
              <option value="">Select…</option>
              <option value="Flue & Wood Heater Clean — $199">Flue &amp; Wood Heater Clean — $199</option>
              <option value="Masonry Brick Chimney Clean — $299">Masonry Brick Chimney Clean — $299</option>
              <option>Blockage / Nest Removal</option>
              <option>Not sure — need advice</option>
            </select>
          </div>
          <div class="field full"><label>Any Details</label><textarea name="message" placeholder="Type of heater or fireplace, any issues you've noticed, when it was last cleaned…"></textarea></div>
        </div>
        <button type="submit" class="form-submit">Send Booking Request ›</button>
      </form>
    </div>
  </section>

  <div class="blog-bottom-pad"></div>

  <a href="tel:0476302729" id="blog-sticky-cta" aria-label="Call or text Dave">
    <span id="blog-sticky-icon">📞</span>
    <span>Call/Text Dave</span>
  </a>

  <script is:inline>
    (function(){
      var btn = document.getElementById('blog-sticky-cta');
      var hero = document.querySelector('.blog-hero');
      function check(){
        var threshold = hero ? hero.offsetHeight : 300;
        if(window.scrollY > threshold){ btn.classList.add('visible'); }
        else { btn.classList.remove('visible'); }
      }
      window.addEventListener('scroll', check, {passive:true});
      check();
    })();
  </script>

</MainLayout>
