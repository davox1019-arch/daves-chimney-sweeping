<MainLayout
  title="Chimney Sweeping Melbourne"
  description="Daves Chimney Sweeping — chimney sweeping, flue cleaning and wood heater cleaning across all Melbourne suburbs VIC. Local, owner-operated. Call 0476 302 729."
  clusterBase="Melbourne"
  clusterRegion="Melbourne and all surrounding suburbs"
  homeHref="/"
  servicePageHref="/chimney-sweeping"
  servicePageLabel="Chimney Sweeping"
>
  <script type="application/ld+json" is:inline set:html={schemaJson}></script>

  <style>
    :root {
      --bd: #1a1a18;
      --bm: #2c2c29;
      --ba: #c8500a;
      --bw: #f5f0e8;
      --wh: #ffffff;
      --tm: #1a1a18;
      --ts: #5a5a54;
      --br: #e2ddd4;
      --rad: 10px;
    }

    /* Hero */
    .hub-hero {
      background: var(--bd);
      color: var(--wh);
      padding: 3.2rem 1.25rem 3rem;
      text-align: center;
    }
    .eyebrow {
      display: inline-block;
      background: var(--ba);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 20px;
      margin-bottom: 1.1rem;
    }
    .hub-hero h1 {
      font-size: clamp(2rem, 6.5vw, 3rem);
      font-weight: 800;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin: 0 0 1.2rem;
      color: var(--wh);
    }
    .hub-hero .lead {
      font-size: 1.05rem;
      line-height: 1.68;
      color: #c8c5be;
      margin: 0 auto 0.85rem;
      max-width: 540px;
    }
    .hub-hero .sub {
      font-size: 0.95rem;
      line-height: 1.6;
      color: #908d86;
      max-width: 500px;
      margin: 0 auto 2.4rem;
    }
    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }
    .btn {
      display: inline-block;
      padding: 1rem 2rem;
      border-radius: var(--rad);
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      width: 100%;
      max-width: 320px;
      transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.88; }
    .btn-call { background: var(--ba); color: #fff; font-size: 1.1rem; }
    .btn-quote { background: transparent; border: 2px solid #5a5a54; color: #c8c5be; }

    /* Trust bar */
    .trust-bar {
      background: var(--bm);
