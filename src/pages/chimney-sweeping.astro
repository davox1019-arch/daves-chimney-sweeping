      <li><a href="/chimney-sweeping/harkness">Chimney Sweeping Harkness</a></li>
      <li><a href="/chimney-sweeping/cobblebank">Chimney Sweeping Cobblebank</a></li>
    </ul>
  </section>

  <section class="card">
    <h2>Sunbury and Nearby Suburbs</h2>
    <ul>
      <li><a href="/chimney-sweeping/sunbury">Chimney Sweeping Sunbury</a></li>
      <li><a href="/chimney-sweeping/diggers-rest">Chimney Sweeping Diggers Rest</a></li>
