import MainLayout from "../layouts/MainLayout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61476302729",
  areaServed: "Melbourne VIC",
  url: "https://daveschimneysweeping.com.au/chimney-sweeping",
  description:
    "Daves Chimney Sweeping provides chimney sweeping, flue cleaning, wood heater cleaning and fireplace cleaning across Melbourne and all surrounding suburbs VIC.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Melbourne",
    addressRegion: "VIC",
    addressCountry: "AU"
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      opens: "08:00",
      closes: "18:00"
    }
  ]
};

const schemaJson = JSON.stringify(localBusinessSchema);

const faqs = [
  {
    q: "How often should a chimney be swept in Melbourne?",
    a: "For a fireplace or wood heater used regularly through Melbourne winters, once a year is the standard guide. If it hasn't been done in a few years — or ever — get it sorted before the cold arrives."
  },
  {
    q: "What's the difference between chimney sweeping and flue cleaning?",
    a: "Chimney sweeping covers the full stack from the firebox up to the chimney pot — removing soot, ash and creosote along the way. Flue cleaning focuses on the pipe or liner that carries smoke out. Most jobs involve both, and we cover whatever your system needs in one visit."
  },
  {
    q: "Do you clean wood heaters as well as open fireplaces?",
    a: "Yes — wood heaters, slow combustion heaters and open fireplaces are all covered. We clean the heater body, the flue connection and the chimney depending on your setup."
  },
  {
    q: "What are the signs my chimney needs cleaning?",
    a: "Smoke coming back into the room, a sluggish or hard-to-light fire, a persistent burnt smell when the fire isn't on, and heavy black soot around the firebox are the most common signs. If it's been over 12 months since the last clean, that's usually reason enough."
  },
  {
    q: "Do you service all Melbourne suburbs?",
    a: "We cover Melbourne's western, north-western and outer suburban corridor — a large area of homes that rely on wood heating. Call 0476 302 729 to confirm we reach your suburb."
  },
  {
    q: "How long does a chimney sweep take?",
    a: "Most jobs take between 45 minutes and an hour and a half depending on the system type and level of buildup. We'll give you a realistic estimate before we start."
  },
  {
    q: "Is chimney sweeping a messy job?",
    a: "We use dust sheets and contain everything properly. Most customers are surprised how tidy we leave things. Soot and ash removal is included in the service."
  },
  {
    q: "How do I get a quote?",
    a: "Call 0476 302 729 or use the contact form. We'll ask a few quick questions about your setup and give you a straight price — no obligation."
  }
];

const services = [
  { icon: "🔥", title: "Chimney Sweeping", desc: "Full clean from firebox to pot. Removes soot, ash and creosote that builds up with regular use." },
  { icon: "🌬️", title: "Flue Cleaning", desc: "Flue liner or pipe cleared and cleaned to restore proper airflow and draw." },
  { icon: "🪵", title: "Wood Heater Cleaning", desc: "Heater body, baffle plate and flue connection cleaned in a single visit." },
  { icon: "🏠", title: "Fireplace Cleaning", desc: "Open and closed fireplace cleaning — firebox, throat and smoke chamber." },
  { icon: "🐦", title: "Blockage Removal", desc: "Bird nests and debris cleared from the flue — common after chimneys sit unused over summer." },
  { icon: "⬛", title: "Soot & Ash Removal", desc: "Thorough removal of built-up soot and ash from all accessible parts of the system." }
];

