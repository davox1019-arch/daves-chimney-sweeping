---
import MainLayout from "../layouts/MainLayout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61 476 302 729",
  areaServed: [
    "Melbourne VIC",
    "Melton VIC 3337",
    "Melton South VIC 3338",
    "Melton West VIC 3337",
    "Brookfield VIC 3338",
    "Kurunjang VIC 3337",
    "Harkness VIC 3337",
    "Cobblebank VIC 3338",
    "Sunbury VIC 3429",
    "Diggers Rest VIC 3427",
    "Gisborne VIC 3437",
    "Riddells Creek VIC 3431",
    "Bacchus Marsh VIC 3340",
    "Darley VIC 3340",
    "Maddingley VIC 3340",
    "Ballan VIC 3342"
  ],
  url: "https://daveschimneysweeping.com.au/chimney-sweeping",
  description:
    "Daves Chimney Sweeping provides chimney sweeping, flue cleaning, wood heater cleaning and fireplace cleaning across Melbourne and surrounding suburbs.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Melbourne",
    addressRegion: "VIC",
    addressCountry: "AU"
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ],
      opens: "08:00",
      closes: "18:00"
    }
  ]
};

const localBusinessSchemaJson = JSON.stringify(localBusinessSchema);
---

<MainLayout
  title="Chimney Sweeping Melbourne"
  description="Need chimney sweeping in Melbourne? Daves Chimney Sweeping provides professional chimney cleaning, flue cleaning and wood heater cleaning across Melbourne and surrounding suburbs."
  clusterBase="Melbourne"
  clusterRegion="Melbourne and surrounding suburbs"
  homeHref="/"
  servicePageHref="/chimney-sweeping"
  servicePageLabel="Chimney Sweeping"
>
  <script type="application/ld+json" is:inline>{localBusinessSchemaJson}</script>

  <section class="hero">
    <h1>Chimney Sweeping Melbourne</h1>
    <p>
      Looking for chimney sweeping in Melbourne? Daves Chimney Sweeping provides
      professional chimney cleaning, flue cleaning and wood heater cleaning
      across Melbourne and surrounding suburbs.
    </p>
    <p>
      We provide straightforward local service, fast quotes and reliable
      workmanship.
    </p>

    <div class="button-row">
      <a class="btn btn-primary" href="/contact">Get a Quote</a>
      <a class="btn btn-secondary" href="tel:0476302729">Call 0476 302 729</a>
    </div>
  </section>

  <section class="card">
    <h2>What Our Chimney Sweeping Service Includes</h2>
    <ul>
      <li>Chimney sweeping</li>
      <li>Flue cleaning</li>
      <li>Wood heater cleaning</li>
      <li>Fireplace cleaning</li>
      <li>Soot and ash buildup removal</li>
      <li>Bird nest and blockage removal</li>
    </ul>
  </section>

  <section class="card">
    <h2>When Homeowners Book Chimney Sweeping</h2>
    <p>
      Many homeowners book chimney sweeping before winter, after a season of
      regular fireplace use, or when they notice smoke drift, soot buildup,
      unusual smells or reduced airflow.
    </p>
    <p>
      Keeping the chimney and flue clean can help your fireplace or wood heater
      work more smoothly during the colder months.
    </p>
  </section>

  <section class="card">
    <h2>Melton and Nearby Suburbs</h2>
    <ul>
      <li><a href="/chimney-sweeping/melton">Chimney Sweeping Melton</a></li>
      <li><a href="/chimney-sweeping/melton-south">Chimney Sweeping Melton South</a></li>
      <li><a href="/chimney-sweeping/melton-west">Chimney Sweeping Melton West</a></li>
      <li><a href="/chimney-sweeping/brookfield">Chimney Sweeping Brookfield</a></li>
