---

<MainLayout
  title="Chimney Sweeping Melbourne | Daves Chimney Sweeping"
  description="Daves Chimney Sweeping — local chimney sweeping, flue cleaning and wood heater cleaning across all Melbourne suburbs VIC. Owner-operated. Call 0476 302 729."
  clusterBase="Melbourne"
  clusterRegion="Melbourne and all surrounding suburbs"
  homeHref="/"
  servicePageHref="/"
  servicePageLabel="Chimney Sweeping"
>
  <script type="application/ld+json" is:inline set:html={schemaJson}></script>

  <style>
    :root {
      --bd:#1a1a18; --bm:#2c2c29; --ba:#c8500a;
      --bw:#f5f0e8; --wh:#ffffff;
      --tm:#1a1a18; --ts:#5a5a54; --br:#e2ddd4; --rad:10px;
    }

    /* ── Hero ─────────────────────────────────── */
    .hero {
      background: var(--bd);
      color: var(--wh);
      padding: 3.4rem 1.25rem 3.2rem;
      text-align: center;
    }
    .eyebrow {
      display: inline-block;
      background: var(--ba);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 20px;
      margin-bottom: 1.1rem;
    }
    .hero h1 {
      font-size: clamp(2.1rem, 7vw, 3.2rem);
      font-weight: 800;
      line-height: 1.07;
      letter-spacing: -0.03em;
      margin: 0 0 1.2rem;
      color: var(--wh);
    }
    .hero h1 em { font-style: normal; color: #f0a06a; }
    .hero .lead {
      font-size: 1.05rem;
      line-height: 1.7;
      color: #c8c5be;
      margin: 0 auto 0.85rem;
      max-width: 540px;
    }
    .hero .sub {
      font-size: 0.95rem;
      line-height: 1.6;
      color: #6e6b64;
      max-width: 500px;
      margin: 0 auto 2.5rem;
    }
    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }
    .btn {
      display: inline-block;
      padding: 1rem 2rem;
      border-radius: var(--rad);
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      width: 100%;
      max-width: 320px;
      transition: opacity 0.15s, transform 0.15s;
    }
    .btn:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-call { background: var(--ba); color: #fff; font-size: 1.15rem; }
    .btn-quote { background: transparent; border: 2px solid #4a4a44; color: #c8c5be; }

    /* ── Trust bar ─────────────────────────────── */
    .trust-bar {
      background: var(--bm);
      padding: 1rem 1.25rem;
      display: flex;
      justify-content: center;
      gap: 1.75rem;
      flex-wrap: wrap;
    }
    .ti {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.8rem;
      color: #908d86;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .ti svg { color: var(--ba); flex-shrink: 0; }

    /* ── Sections ──────────────────────────────── */
    .sec {
      padding: 2.5rem 1.25rem;
      max-width: 760px;
      margin: 0 auto;
    }
    .sec + .sec { border-top: 1px solid var(--br); }
    .sec-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ba);
      margin-bottom: 0.55rem;
    }
    .sec h2 {
      font-size: clamp(1.35rem, 4vw, 1.75rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--tm);
      margin: 0 0 1rem;
      line-height: 1.2;
    }
    .sec p {
      font-size: 0.97rem;
      line-height: 1.72;
      color: var(--ts);
      margin: 0 0 0.9rem;
    }
    .sec p:last-child { margin-bottom: 0; }

    /* ── Service grid ──────────────────────────── */
    .svc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: 1.4rem;
    }
    @media (max-width: 400px) { .svc-grid { grid-template-columns: 1fr; } }
    .svc-card {
      background: var(--bw);
      border: 1px solid var(--br);
      border-radius: var(--rad);
      padding: 1.1rem 1rem;
    }
    .svc-icon { font-size: 1.5rem; display: block; margin-bottom: 0.5rem; }
    .svc-title { font-size: 0.9rem; font-weight: 700; color: var(--tm); margin-bottom: 0.3rem; }
    .svc-desc { font-size: 0.82rem; line-height: 1.55; color: var(--ts); }

    /* ── Why book cards ────────────────────────── */
    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.7rem;
      margin-top: 1.4rem;
    }
    @media (max-width: 480px) { .why-grid { grid-template-columns: 1fr; } }
    .why-card {
      background: var(--bw);
      border: 1px solid var(--br);
      border-radius: var(--rad);
      padding: 1rem;
    }
    .why-icon { font-size: 1.3rem; display: block; margin-bottom: 0.4rem; }
    .why-title { font-size: 0.88rem; font-weight: 700; color: var(--tm); margin-bottom: 0.25rem; }
    .why-desc { font-size: 0.81rem; line-height: 1.5; color: var(--ts); }

    /* ── About card ────────────────────────────── */
    .about-card {
      background: var(--bw);
      border: 1px solid var(--br);
      border-radius: var(--rad);
      padding: 1.5rem 1.25rem;
      margin-top: 1.1rem;
    }
    .about-card p { font-size: 0.96rem; line-height: 1.7; color: var(--ts); margin: 0 0 0.85rem; }
    .about-card p:last-child { margin-bottom: 0; }
    .arow { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--ts); margin-top: 0.6rem; }
    .arow strong { color: var(--tm); }
    .arow a { color: var(--ba); font-weight: 700; text-decoration: none; }

    /* ── Suburb accordion ──────────────────────── */
    .suburb-intro {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--ts);
      margin-bottom: 1.25rem;
    }
    .region-accordion {
      border: 1px solid var(--br);
      border-radius: var(--rad);
      overflow: hidden;
      margin-bottom: 0;
    }
    details.region-item {
      border-bottom: 1px solid var(--br);
    }
    details.region-item:last-child { border-bottom: none; }
    details.region-item summary {
      padding: 0.9rem 1.1rem;
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--tm);
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      background: var(--wh);
      transition: background 0.15s;
      gap: 1rem;
    }
    details.region-item summary::-webkit-details-marker { display: none; }
    details.region-item summary:hover { background: var(--bw); }
    .region-name { flex: 1; }
    .region-count {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--ts);
      background: var(--bw);
      border: 1px solid var(--br);
      border-radius: 20px;
      padding: 0.15rem 0.6rem;
      white-space: nowrap;
    }
    details.region-item summary::after {
      content: "﹢";
      font-size: 1.2rem;
      font-weight: 400;
      color: var(--ba);
      flex-shrink: 0;
    }
    details.region-item[open] summary { background: var(--bw); }
    details.region-item[open] summary::after { content: "−"; }
    .region-body {
      padding: 0.85rem 1.1rem 1rem;
      background: var(--wh);
      border-top: 1px solid var(--br);
    }
    .suburb-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    a.chip {
      display: inline-block;
      background: var(--wh);
      border: 1px solid var(--ba);
      border-radius: 6px;
      padding: 0.3rem 0.65rem;
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--ba);
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
    }
    a.chip:hover { background: var(--ba); color: #fff; }
    span.chip {
      display: inline-block;
      background: var(--bw);
      border: 1px solid var(--br);
      border-radius: 6px;
      padding: 0.3rem 0.65rem;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--ts);
      white-space: nowrap;
    }

    /* ── FAQ ───────────────────────────────────── */
    .faq-list {
      margin-top: 1.4rem;
      border: 1px solid var(--br);
      border-radius: var(--rad);
      overflow: hidden;
    }
    details.faq-item { border-bottom: 1px solid var(--br); }
