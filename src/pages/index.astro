---
import MainLayout from "../layouts/MainLayout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61476302729",
  areaServed: "Melbourne VIC",
  url: "https://daveschimneysweeping.com.au/",
  description:
    "Daves Chimney Sweeping provides chimney sweeping, flue cleaning, wood heater cleaning and fireplace cleaning across Melbourne and all surrounding suburbs VIC.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Melbourne",
    addressRegion: "VIC",
    addressCountry: "AU"
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      opens: "08:00",
      closes: "18:00"
    }
  ]
};

const schemaJson = JSON.stringify(localBusinessSchema);

const faqs = [
  {
    q: "How often should a chimney be swept in Melbourne?",
    a: "For a fireplace or wood heater used regularly through Melbourne winters, once a year is the standard. If it hasn't been done in a couple of years — or ever — sort it before the cold arrives."
  },
  {
    q: "What's the difference between chimney sweeping and flue cleaning?",
    a: "Chimney sweeping covers the full stack from firebox to pot — removing soot, ash and creosote. Flue cleaning targets the liner or pipe that carries smoke out. Most jobs involve both in the one visit."
  },
  {
    q: "Do you clean wood heaters as well as open fireplaces?",
    a: "Yes — wood heaters, slow combustion heaters and open fireplaces all covered. We clean the heater body, flue connection and chimney depending on your setup."
  },
  {
    q: "What are the signs my chimney needs cleaning?",
    a: "Smoke coming back into the room, fires that won't draw, a persistent burnt smell when the fire's off, and heavy black soot around the firebox. Over 12 months since the last clean is usually reason enough."
  },
  {
    q: "Do you service all Melbourne suburbs?",
    a: "We cover Melbourne's western, north-west and outer corridor. Call 0476 302 729 to confirm we reach your suburb — we'll tell you in seconds."
  },
  {
    q: "How long does a chimney sweep take?",
    a: "Between 45 minutes and an hour and a half, depending on system type and buildup level. We'll give you a realistic estimate before we start."
  },
  {
    q: "Is it a messy job?",
    a: "We put down dust sheets and contain everything. Most customers are surprised how tidy we leave it. Soot and ash removal is part of the service."
  },
  {
    q: "How do I get a quote?",
    a: "Call 0476 302 729 or fill in the form on the contact page. A few questions about your setup and we'll give you a straight price — no obligation."
  }
];

const services = [
  { icon: "🔥", title: "Chimney Sweeping", desc: "Full clean from firebox to pot. Removes soot, ash and creosote that builds up over winter." },
  { icon: "🌬️", title: "Flue Cleaning", desc: "Flue liner or pipe cleared to restore proper airflow and draw." },
  { icon: "🪵", title: "Wood Heater Cleaning", desc: "Heater body, baffle plate and flue connection cleaned in one visit." },
  { icon: "🏠", title: "Fireplace Cleaning", desc: "Open and closed fireplace cleaning — firebox, throat and smoke chamber." },
  { icon: "🐦", title: "Blockage Removal", desc: "Bird nests and debris cleared — common in chimneys left unused over summer." },
  { icon: "⬛", title: "Soot & Ash Removal", desc: "Thorough removal of built-up soot and ash from all accessible parts of the system." }
];

