  description: "Daves Chimney Sweeping — $199 chimney inspection and full clean across all Melbourne suburbs VIC. Local, owner-operated.",
  address: { "@type": "PostalAddress", addressLocality: "Melbourne", addressRegion: "VIC", addressCountry: "AU" },
  openingHoursSpecification: [{ "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], opens: "08:00", closes: "18:00" }]
};
const schemaJson = JSON.stringify(localBusinessSchema);

const faqs = [
  { q: "How much does a chimney sweep cost?", a: "$199 flat rate — that covers a full chimney inspection and clean. No call-out fee, no hidden extras. The price is the same regardless of which Melbourne suburb you're in." },
  { q: "How often should a chimney be swept in Melbourne?", a: "For a fireplace or wood heater used regularly through winter, once a year is the standard. If it hasn't been done in a few years — or ever — get it sorted before the cold arrives." },
  { q: "What's included in the $199 chimney clean?", a: "Full chimney sweep from firebox to pot, flue cleaning, soot and ash removal, blockage check, bird nest clearing if needed, and a verbal condition report. Everything in one visit." },
  { q: "Do you clean wood heaters as well as open fireplaces?", a: "Yes — wood heaters, slow combustion heaters and open fireplaces all covered. We clean the heater body, flue connection and chimney depending on your setup." },
  { q: "What are the signs my chimney needs cleaning?", a: "Smoke coming back into the room, a sluggish fire, a persistent burnt smell when the fire isn't on, and heavy black soot around the firebox. Over 12 months since the last clean is usually reason enough." },
  { q: "Do you service all Melbourne suburbs?", a: "We cover Melbourne's western, north-western and outer corridor — a large area of homes that rely on wood heating. Call 0476 302 729 to confirm we reach your suburb." },
  { q: "How long does a chimney sweep take?", a: "Between 45 minutes and an hour and a half, depending on the system and level of buildup. We'll give you a realistic estimate before we start." },
  { q: "Is chimney sweeping a messy job?", a: "We put down dust sheets and contain everything properly. Most customers are surprised how tidy we leave it. Soot and ash removal is included as part of the service." }
];

const services = [
  { icon: "🔥", title: "Chimney Sweeping", desc: "Full clean from firebox to pot. Removes soot, ash and creosote that builds up with regular use." },
  { icon: "🌬️", title: "Flue Cleaning", desc: "Flue liner or pipe cleared and cleaned to restore proper airflow and draw." },
  { icon: "🪵", title: "Wood Heater Cleaning", desc: "Heater body, baffle plate and flue connection cleaned in a single visit." },
  { icon: "🏠", title: "Fireplace Cleaning", desc: "Open and closed fireplace cleaning — firebox, throat and smoke chamber." },
  { icon: "🐦", title: "Blockage Removal", desc: "Bird nests and debris cleared — common after chimneys sit unused over summer." },
  { icon: "⬛", title: "Soot & Ash Removal", desc: "Thorough removal of built-up soot and ash from all accessible parts of the system." }
];

