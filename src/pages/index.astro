---

<MainLayout
  title="Chimney Sweeping Melbourne — $199 Clean & Inspect | Daves"
  description="Daves Chimney Sweeping — $199 chimney inspection & full clean across all Melbourne suburbs VIC. Local, owner-operated. No call-out fee. Call 0476 302 729."
  clusterBase="Melbourne"
  clusterRegion="Melbourne and all surrounding suburbs"
  homeHref="/"
  servicePageHref="/"
  servicePageLabel="Chimney Sweeping"
>
  <script type="application/ld+json" is:inline set:html={schemaJson}></script>

  <style>
    :root{--bd:#1a1a18;--bm:#2c2c29;--ba:#c8500a;--bw:#f5f0e8;--wh:#ffffff;--tm:#1a1a18;--ts:#5a5a54;--br:#e2ddd4;--rad:10px}

    /* Hero */
    .hub-hero{background:var(--bd);color:var(--wh);padding:3.4rem 1.25rem 3.2rem;text-align:center}
    .eyebrow{display:inline-block;background:var(--ba);color:#fff;font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.3rem .9rem;border-radius:20px;margin-bottom:1.1rem}
    .hub-hero h1{font-size:clamp(2.1rem,7vw,3.2rem);font-weight:800;line-height:1.07;letter-spacing:-.03em;margin:0 0 .9rem;color:var(--wh)}
    .hub-hero h1 em{font-style:normal;color:#f0a06a}
    .price-badge{display:inline-flex;align-items:center;gap:.5rem;background:#1e4d14;color:#7edd5a;font-size:.88rem;font-weight:800;padding:.45rem 1.1rem;border-radius:20px;margin-bottom:1rem;border:1px solid #2a6b1c}
    .hub-hero .lead{font-size:1.05rem;line-height:1.7;color:#c8c5be;margin:0 auto .8rem;max-width:540px}
    .hub-hero .sub{font-size:.95rem;line-height:1.6;color:#6e6b64;max-width:500px;margin:0 auto 2.4rem}
    .btn-row{display:flex;flex-direction:column;gap:.75rem;align-items:center}
    .btn{display:inline-block;padding:1rem 2rem;border-radius:var(--rad);font-size:1rem;font-weight:700;text-decoration:none;text-align:center;width:100%;max-width:320px;transition:opacity .15s,transform .15s}
    .btn:hover{opacity:.88;transform:translateY(-1px)}
    .btn-call{background:var(--ba);color:#fff;font-size:1.15rem}
    .btn-quote{background:transparent;border:2px solid #4a4a44;color:#c8c5be}

    /* Trust bar */
    .trust-bar{background:var(--bm);padding:1rem 1.25rem;display:flex;justify-content:center;gap:1.75rem;flex-wrap:wrap}
    .ti{display:flex;align-items:center;gap:.45rem;font-size:.82rem;color:#908d86;font-weight:600;letter-spacing:.04em;text-transform:uppercase}
    .ti svg{color:var(--ba);flex-shrink:0}

    /* Sections */
    .sec{padding:2.5rem 1.25rem;max-width:760px;margin:0 auto}
    .sec+.sec{border-top:1px solid var(--br)}
    .sec-label{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ba);margin-bottom:.55rem}
    .sec h2{font-size:clamp(1.4rem,4vw,1.8rem);font-weight:800;letter-spacing:-.02em;color:var(--tm);margin:0 0 1rem;line-height:1.2}
    .sec p{font-size:1rem;line-height:1.75;color:var(--ts);margin:0 0 .9rem}
    .sec p:last-child{margin-bottom:0}

    /* Services */
    .svc-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:1.4rem}
    @media(max-width:400px){.svc-grid{grid-template-columns:1fr}}
    .svc-card{background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:1.1rem 1rem}
    .svc-icon{font-size:1.5rem;display:block;margin-bottom:.5rem}
    .svc-title{font-size:.92rem;font-weight:700;color:var(--tm);margin-bottom:.3rem}
    .svc-desc{font-size:.84rem;line-height:1.55;color:var(--ts)}

    /* Why cards */
    .why-grid{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-top:1.4rem}
    @media(max-width:480px){.why-grid{grid-template-columns:1fr}}
    .wc{background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:1rem}
    .wc-icon{font-size:1.3rem;display:block;margin-bottom:.4rem}
    .wc-title{font-size:.9rem;font-weight:700;color:var(--tm);margin-bottom:.25rem}
    .wc-desc{font-size:.83rem;line-height:1.5;color:var(--ts)}

    /* About */
    .about-card{background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:1.5rem 1.25rem;margin-top:1.1rem}
    .about-card p{font-size:1rem;line-height:1.7;color:var(--ts);margin:0 0 .85rem}
    .about-card p:last-child{margin-bottom:0}
    .arow{display:flex;align-items:center;gap:.5rem;font-size:.9rem;color:var(--ts);margin-top:.6rem}
    .arow strong{color:var(--tm)}
    .arow a{color:var(--ba);font-weight:700;text-decoration:none}

    /* ── SUBURB ACCORDION ── */
    .clusters-intro{font-size:1rem;line-height:1.75;color:var(--ts);margin-bottom:1.25rem}
    .region-accordion{border:1px solid var(--br);border-radius:var(--rad);overflow:hidden}
    details.region-item{border-bottom:1px solid var(--br)}
    details.region-item:last-child{border-bottom:none}
    details.region-item summary{
      padding:.9rem 1.1rem;font-size:.92rem;font-weight:700;color:var(--tm);
      cursor:pointer;list-style:none;display:flex;justify-content:space-between;
      align-items:center;user-select:none;background:var(--wh);transition:background .15s;gap:1rem
    }
    details.region-item summary::-webkit-details-marker{display:none}
    details.region-item summary:hover{background:var(--bw)}
    details.region-item[open] summary{background:var(--bw)}
