---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Daves Chimney Sweeping Melbourne"
  description="Local chimney sweeping in Melbourne. Fast quotes, reliable service, and professional chimney and flue cleaning."
  clusterBase="Melbourne"
  clusterRegion="Melbourne and surrounding suburbs"
homeHref="/"
servicePageHref="/chimney-sweeping"
servicePageLabel="Chimney Sweeping"
>
  <section class="hero">
    <h1>Daves Chimney Sweeping Melbourne</h1>
    <p>
      Local chimney sweeping, flue cleaning and wood heater cleaning across
      Melbourne and surrounding suburbs.
    </p>
    <p>
      Fast quotes, friendly service and straightforward local workmanship.
    </p>

    <div class="button-row">
      <a class="btn btn-primary" href="/contact">Get a Quote</a>
      <a class="btn btn-secondary" href="/chimney-sweeping">View Services</a>
    </div>
  </section>

  <div class="grid">
    <section class="card">
      <h2>Our Services</h2>
      <ul>
        <li>Chimney sweeping</li>
        <li>Flue cleaning</li>
        <li>Wood heater cleaning</li>
        <li>Bird nest and blockage removal</li>
      </ul>
    </section>

    <section class="card">
      <h2>Why Choose Us</h2>
      <p>
        We keep things simple. Clear quotes, local service and a clean,
        mobile-friendly site that makes it easy to get in touch.
      </p>
    </section>
  </div>

  <section class="card">
    <h2>Areas We Service</h2>
    <p>
      We provide chimney sweeping services across Melbourne, including Melton,
      Sunbury, Melton South, Melton West, Brookfield, Kurunjang, Harkness,
      Cobblebank, Diggers Rest and surrounding areas.
    </p>
  </section>
</MainLayout>