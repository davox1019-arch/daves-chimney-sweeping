---
import MainLayout from "../../layouts/MainLayout.astro";

const faqs = [
  {
    q: "How cold does it get in Ballan — does that affect how often I should clean the chimney?",
    a: "Ballan is one of the cooler spots in the region, sitting at higher elevation. Homes here often use their wood heaters more heavily than Melbourne metro properties, which means flues can accumulate buildup faster. Annual cleaning is a sensible habit."
  },
  {
    q: "Do you service Ballan as part of a regular run, or is it a special trip?",
    a: "Ballan VIC 3342 is part of our Bacchus Marsh service area — we're out this way regularly."
  },
  {
    q: "Can I book a chimney sweep and a wood heater clean in the same visit?",
    a: "Yes — most jobs cover both. We'll clean the chimney, the flue and the heater in one visit."
  },
  {
    q: "What if I can smell smoke but there's no visible buildup?",
    a: "Smell without obvious soot can mean creosote buildup higher up in the flue where you can't see it. It's worth getting it looked at — a clean usually resolves it."
  }
];
---

<MainLayout
  title="Chimney Sweeping Ballan VIC 3342"
  description="Chimney sweeping in Ballan VIC 3342. Daves Chimney Sweeping provides flue cleaning, wood heater servicing and fireplace maintenance. Local service, fast quotes."
  clusterBase="Bacchus Marsh"
  clusterRegion="Bacchus Marsh and nearby suburbs"
  homeHref="/chimney-sweeping/bacchus-marsh"
  servicePageHref="/chimney-sweeping/bacchus-marsh"
  servicePageLabel="Bacchus Marsh Chimney Sweeping"
>
  <style>
    :root { --brand-dark: #1a1a18; --brand-mid: #2c2c29; --brand-accent: #c8500a; --brand-warm: #f5f0e8; --brand-white: #ffffff; --text-main: #1a1a18; --text-muted: #5a5a54; --border: #e2ddd4; --radius: 10px; }
    .hero { background: var(--brand-dark); color: var(--brand-white); padding: 2.8rem 1.25rem 2.5rem; text-align: center; }
    .hero-eyebrow { display: inline-block; background: var(--brand-accent); color: #fff; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.3rem 0.85rem; border-radius: 20px; margin-bottom: 1.1rem; }
    .hero h1 { font-size: clamp(1.65rem, 5vw, 2.2rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--brand-white); }
    .hero-lead { font-size: 1rem; line-height: 1.65; color: #c8c5be; margin: 0 auto 0.75rem; max-width: 480px; }
    .hero-sub { font-size: 0.93rem; line-height: 1.6; color: #908d86; max-width: 480px; margin: 0 auto 2rem; }
    .btn-row { display: flex; flex-direction: column; gap: 0.75rem; align-items: center; }
    .btn { display: inline-block; padding: 0.95rem 2rem; border-radius: var(--radius); font-size: 1rem; font-weight: 700; text-decoration: none; text-align: center; width: 100%; max-width: 320px; transition: opacity 0.15s; }
    .btn:hover { opacity: 0.88; }
    .btn-call { background: var(--brand-accent); color: #fff; font-size: 1.1rem; }
    .btn-quote { background: transparent; border: 2px solid #5a5a54; color: #c8c5be; }
    .section { padding: 2.2rem 1.25rem; max-width: 680px; margin: 0 auto; }
    .section + .section { border-top: 1px solid var(--border); }
    .section-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand-accent); margin-bottom: 0.55rem; }
    .section h2 { font-size: clamp(1.25rem, 4vw, 1.6rem); font-weight: 800; letter-spacing: -0.02em; color: var(--text-main); margin: 0 0 1rem; line-height: 1.25; }
    .section p { font-size: 0.97rem; line-height: 1.7; color: var(--text-muted); margin: 0 0 0.85rem; }
    .section p:last-child { margin-bottom: 0; }
    /* Unique: highlight box */
    .highlight-box { background: var(--brand-warm); border-left: 3px solid var(--brand-accent); border-radius: 0 var(--radius) var(--radius) 0; padding: 1rem 1.25rem; margin-top: 1rem; font-size: 0.95rem; line-height: 1.65; color: var(--text-muted); }
    .check-list { list-style: none; padding: 0; margin: 1.1rem 0 0; display: flex; flex-direction: column; gap: 0.65rem; }
    .check-list li { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.95rem; line-height: 1.5; color: var(--text-muted); }
    .check-list li::before { content: "✓"; color: var(--brand-accent); font-weight: 800; flex-shrink: 0; }
    .about-card { background: var(--brand-warm); border-radius: var(--radius); border: 1px solid var(--border); padding: 1.5rem 1.25rem; margin-top: 1rem; }
    .about-card p { font-size: 0.96rem; line-height: 1.7; color: var(--text-muted); margin: 0 0 0.8rem; }
    .about-detail { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--text-muted); margin-top: 0.5rem; }
    .about-detail strong { color: var(--text-main); }
    .about-detail a { color: var(--brand-accent); font-weight: 700; text-decoration: none; }
    .faq-list { display: flex; flex-direction: column; margin-top: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    details.faq-item { border-bottom: 1px solid var(--border); }
    details.faq-item:last-child { border-bottom: none; }
    details.faq-item summary { padding: 1rem 1.1rem; font-size: 0.95rem; font-weight: 700; color: var(--text-main); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; user-select: none; background: var(--brand-white); transition: background 0.15s; }
    details.faq-item summary::-webkit-details-marker { display: none; }
    details.faq-item summary:hover { background: var(--brand-warm); }
    details.faq-item summary::after { content: "+"; font-size: 1.3rem; font-weight: 400; color: var(--brand-accent); flex-shrink: 0; margin-left: 1rem; }
    details.faq-item[open] summary::after { content: "−"; }
    .faq-answer { padding: 0 1.1rem 1rem; font-size: 0.93rem; line-height: 1.7; color: var(--text-muted); background: var(--brand-white); }
    .suburb-chips { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-top: 1.1rem; }
    .suburb-chip { display: inline-block; background: var(--brand-warm); border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.85rem; font-size: 0.84rem; font-weight: 600; color: var(--text-main); text-decoration: none; transition: background 0.15s, border-color 0.15s; }
    .suburb-chip:hover { background: var(--brand-accent); border-color: var(--brand-accent); color: #fff; }
    .page-links { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.1rem; }
    .page-link { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; background: var(--brand-warm); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; font-size: 0.93rem; font-weight: 600; color: var(--text-main); transition: background 0.15s, border-color 0.15s; }
    .page-link:hover { background: var(--brand-accent); border-color: var(--brand-accent); color: #fff; }
    .page-link span { opacity: 0.5; font-size: 1.1rem; }
    .bottom-cta { background: var(--brand-dark); color: var(--brand-white); padding: 2.5rem 1.25rem; text-align: center; }
    .bottom-cta h2 { font-size: clamp(1.3rem, 4.5vw, 1.7rem); font-weight: 800; letter-spacing: -0.02em; color: var(--brand-white); margin: 0 0 0.6rem; }
    .bottom-cta p { font-size: 0.95rem; color: #908d86; margin: 0 0 1.75rem; line-height: 1.6; }
  </style>

  <section class="hero">
    <span class="hero-eyebrow">Ballan VIC 3342</span>
    <h1>Chimney Sweeping<br>Ballan VIC 3342</h1>
    <p class="hero-lead">
      Ballan sits at a higher elevation than most of the region — winters here are colder and wood heaters work overtime. Daves Chimney Sweeping keeps chimneys and flues clean and working properly for Ballan homes.
    </p>
    <p class="hero-sub">
      Local, owner-operated, and part of our regular Bacchus Marsh area run.
    </p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

  <section class="section">
    <p class="section-label">Why it matters</p>
    <h2>Why Ballan Homes Benefit From Regular Chimney Cleaning</h2>
    <p>
      In a cooler climate like Ballan VIC 3342, wood heaters often run for longer and more frequently than in warmer parts of the state. That means flues and chimneys accumulate soot and creosote faster.
    </p>
    <div class="highlight-box">
      A clean flue draws better, smells less, and is less likely to give you trouble mid-winter when you need the heater most. It's the kind of maintenance that's easy to put off — until it becomes a problem.
    </div>
  </section>

  <section class="section">
    <p class="section-label">What's included</p>
    <h2>Chimney &amp; Heater Cleaning Services in Ballan</h2>
    <p>We handle all the core chimney and heating maintenance for Ballan homes:</p>
    <ul class="check-list">
      <li>Chimney sweeping — stack and firebox cleaned thoroughly</li>
      <li>Flue cleaning — liner or pipe cleared for proper airflow</li>
      <li>Wood heater service — heater body, baffle and connections</li>
      <li>Open fireplace cleaning — firebox and smoke chamber</li>
      <li>Soot, ash and creosote removal</li>
      <li>Nest and debris blockage clearing</li>
    </ul>
  </section>

  <section class="section">
    <p class="section-label">About us</p>
    <h2>Owner-Operated, Out This Way Regularly</h2>
    <div class="about-card">
      <p>
        Daves Chimney Sweeping covers Ballan VIC 3342 as part of the Bacchus Marsh service area. It's an owner-operated business — Dave does the work himself, which means you get consistent service and a direct line if you have questions.
      </p>
      <div class="about-detail">📞 <strong>Phone:</strong>&nbsp;<a href="tel:0476302729">0476 302 729</a></div>
      <div class="about-detail">📍 <strong>Service area:</strong>&nbsp;Ballan VIC 3342 and surrounds</div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">Nearby areas</p>
    <h2>Other Suburbs We Cover Near Ballan</h2>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/bacchus-marsh">Bacchus Marsh 3340</a>
      <a class="suburb-chip" href="/chimney-sweeping/darley">Darley 3340</a>
      <a class="suburb-chip" href="/chimney-sweeping/maddingley">Maddingley 3340</a>
    </div>
  </section>

  <section class="section">
    <p class="section-label">FAQs</p>
    <h2>Ballan Chimney Sweeping — Common Questions</h2>
    <div class="faq-list">
      {faqs.map(({ q, a }) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <div class="faq-answer">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="section-label">More pages</p>
    <h2>Nearby Service Pages</h2>
    <nav class="page-links" aria-label="Nearby suburb pages">
      <a class="page-link" href="/chimney-sweeping/bacchus-marsh">Chimney Sweeping — Bacchus Marsh VIC 3340 <span>›</span></a>
      <a class="page-link" href="/chimney-sweeping/darley">Chimney Sweeping — Darley VIC 3340 <span>›</span></a>
      <a class="page-link" href="/chimney-sweeping/maddingley">Chimney Sweeping — Maddingley VIC 3340 <span>›</span></a>
      <a class="page-link" href="/contact">Get a Quote <span>›</span></a>
    </nav>
  </section>

  <section class="bottom-cta">
    <h2>Book a Chimney Sweep in Ballan</h2>
    <p>Give Dave a call or drop us a message — we'll sort out a time and confirm the details.</p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
