---
import MainLayout from "../../layouts/MainLayout.astro";
import SuburbSeo from "../../components/SuburbSeo.astro";

const pageTitle = "Chimney Sweep Research VIC 3095 - $199 Clean & Inspect";
const pageDescription = "Chimney sweeping Research VIC 3095 - $199 chimney inspection and full clean. Flue cleaning, wood heater service, owner-operated. Call 0476 302 729.";
const suburb = "Research";
const postcode = "3095";
const faqs = [
  {
    "q": "Is Research VIC 3095 the same area as Eltham?",
    "a": "Research is a separate suburb but shares postcode 3095 with Eltham. They're neighbours and we service both."
  },
  {
    "q": "Does the tree coverage around Research affect chimney cleaning?",
    "a": "It means bird nesting in chimneys is more common — we deal with it as standard. Debris from nearby trees can also block flues, so it's worth checking annually."
  },
  {
    "q": "What's the easiest way to get a quote for Research?",
    "a": "Call 0476 302 729 — usually the fastest. Or use the form on this page and we'll come back to you the same day."
  },
  {
    "q": "Do you clean both slow combustion heaters and open fireplaces?",
    "a": "Yes — both are covered. We handle whatever type of system your Research home has installed."
  },
  {
    "q": "How long has Daves Chimney Sweeping been operating?",
    "a": "Daves Chimney Sweeping is owner-operated and services the north-east Melbourne corridor including Research and nearby areas."
  }
];
const nearbySuburbs = [
  {
    "slug": "eltham",
    "label": "Eltham 3095"
  },
  {
    "slug": "eltham-north",
    "label": "Eltham North 3095"
  },
  {
    "slug": "diamond-creek",
    "label": "Diamond Creek 3089"
  },
  {
    "slug": "hurstbridge",
    "label": "Hurstbridge 3099"
  }
];
