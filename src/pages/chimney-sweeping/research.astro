    .suburb-chip:hover { background: var(--brand-accent); border-color: var(--brand-accent); color: #fff; }
    .page-links { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; }
    .page-link { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; background: var(--brand-warm); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; font-size: 0.93rem; font-weight: 600; color: var(--text-main); transition: background 0.15s, border-color 0.15s; }
    .page-link:hover { background: var(--brand-accent); border-color: var(--brand-accent); color: #fff; }
    .page-link span { opacity: 0.5; font-size: 1.1rem; }
    .bottom-cta { background: url('/images/fireplace3.jpg') center/cover no-repeat; color: var(--brand-white); padding: 2.8rem 1rem; text-align: center; }
    .bottom-cta-inner { background: rgba(10,6,4,0.62); border-radius: 14px; padding: 1.75rem 1.5rem; max-width: 480px; margin: 0 auto; }
    .bottom-cta-inner .btn-row { flex-direction: column; gap: .5rem; width: 100%; }
    .bottom-cta-inner .btn { max-width: none; width: calc(100% - 1rem); box-sizing: border-box; padding: .9rem 1rem; font-size: 1rem; }
    .bottom-cta-inner .btn-call { font-size: 1rem; }
    .bottom-cta h2 { font-size: clamp(1.65rem, 5vw, 2.1rem); font-weight: 800; letter-spacing: -0.02em; color: var(--brand-white); margin: 0 0 0.6rem; }
