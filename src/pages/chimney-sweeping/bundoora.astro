  {
    "q": "What's the best way to contact you for Bundoora?",
    "a": "Call 0476 302 729 — fastest option. Or use the quote form on this page and we'll get back to you promptly."
  },
  {
    "q": "Do you charge extra for Bundoora versus more central suburbs?",
    "a": "No. We quote based on the job, not the location within our service area."
  }
];
const nearbySuburbs = [
  {
    "slug": "heidelberg",
    "label": "Heidelberg 3084"
  },
  {
    "slug": "watsonia",
    "label": "Watsonia 3087"
  },
  {
    "slug": "macleod",
    "label": "Macleod 3085"
  },
  {
    "slug": "greensborough",
    "label": "Greensborough 3088"
  },
  {
    "slug": "eltham",
    "label": "Eltham 3095"
