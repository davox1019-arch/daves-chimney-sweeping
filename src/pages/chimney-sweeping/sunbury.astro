  <section class="bottom-cta">
    <h2>Get Your Sunbury Chimney Sorted</h2>
    <p>Call Dave directly for a no-fuss quote, or send us a message and we'll get back to you.</p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

</MainLayout>
