---
import MainLayout from "../../layouts/MainLayout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61476302729",
  areaServed: [
    "Sunbury VIC 3429",
    "Diggers Rest VIC 3427",
    "Gisborne VIC 3437",
    "Riddells Creek VIC 3431",
    "Wildwood VIC 3429",
    "Bulla VIC 3428",
    "Clarkefield VIC 3430"
  ],
  url: "https://daveschimneysweeping.com.au/chimney-sweeping/sunbury",
  description:
    "Daves Chimney Sweeping provides chimney sweeping, flue cleaning, wood heater cleaning and fireplace servicing in Sunbury VIC 3429 and nearby suburbs.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Sunbury",
    addressRegion: "VIC",
    postalCode: "3429",
    addressCountry: "AU"
  }
};

const localBusinessSchemaJson = JSON.stringify(localBusinessSchema);

const faqs = [
  {
    q: "Do you cover the whole of Sunbury?",
    a: "Yes — we service Sunbury VIC 3429 and the surrounding suburbs. Give us a call if you're not sure and we'll confirm."
  },
  {
    q: "What's the difference between chimney sweeping and flue cleaning?",
    a: "Chimney sweeping focuses on removing soot and debris from the chimney stack itself. Flue cleaning targets the liner or pipe that carries smoke from your fireplace or wood heater out of the house. Most jobs involve both."
  },
  {
    q: "How often should I get my chimney cleaned?",
    a: "For a fireplace or wood heater used regularly through winter, once a year is a reasonable guide. If you've had heavy use or haven't had it done in a few years, it's worth getting it looked at sooner."
  },
  {
    q: "What if I don't know when it was last cleaned?",
    a: "That's completely fine — we'll assess it on the day. If there's significant buildup or a blockage, we'll let you know what we find before we go any further."
  },
  {
    q: "Do you service wood heaters as well as open fireplaces?",
    a: "Yes. Wood heaters, slow combustion heaters and open fireplaces are all covered. We clean the heater, the flue and the chimney as needed."
  }
];
---

<MainLayout
  title="Chimney Sweeping Sunbury VIC 3429"
  description="Local chimney sweeping in Sunbury VIC 3429. Daves Chimney Sweeping handles flue cleaning, wood heater servicing and fireplace cleaning. Fast quotes, no fuss."
  clusterBase="Sunbury"
  clusterRegion="Sunbury, Diggers Rest and nearby suburbs"
  homeHref="/chimney-sweeping/sunbury"
  servicePageHref="/chimney-sweeping/sunbury"
  servicePageLabel="Sunbury Chimney Sweeping"
>
  <script type="application/ld+json" is:inline set:html={localBusinessSchemaJson}></script>

  <style>
    :root {
      --brand-dark:   #1a1a18;
      --brand-mid:    #2c2c29;
      --brand-accent: #c8500a;
      --brand-warm:   #f5f0e8;
      --brand-white:  #ffffff;
      --text-main:    #1a1a18;
      --text-muted:   #5a5a54;
      --border:       #e2ddd4;
      --radius:       10px;
      --shadow-card:  0 2px 12px rgba(0,0,0,0.07);
    }

    .hero {
      background: var(--brand-dark);
      color: var(--brand-white);
      padding: 2.8rem 1.25rem 2.5rem;
      text-align: center;
    }
    .hero-eyebrow {
      display: inline-block;
      background: var(--brand-accent);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border-radius: 20px;
      margin-bottom: 1.1rem;
    }
    .hero h1 {
      font-size: clamp(1.65rem, 5vw, 2.2rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
      color: var(--brand-white);
    }
    .hero-lead {
      font-size: 1rem;
      line-height: 1.65;
      color: #c8c5be;
      margin: 0 auto 0.75rem;
      max-width: 480px;
    }
    .hero-sub {
      font-size: 0.93rem;
      line-height: 1.6;
      color: #908d86;
      max-width: 480px;
      margin: 0 auto 2rem;
    }
    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }
    .btn {
      display: inline-block;
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      width: 100%;
      max-width: 320px;
      transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.88; }
    .btn-call {
      background: var(--brand-accent);
      color: #fff;
      font-size: 1.1rem;
    }
    .btn-quote {
      background: transparent;
      border: 2px solid #5a5a54;
      color: #c8c5be;
    }

    .trust-bar {
      background: var(--brand-mid);
      padding: 0.95rem 1.25rem;
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: #908d86;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .trust-item svg { flex-shrink: 0; color: var(--brand-accent); }

    .section {
      padding: 2.2rem 1.25rem;
      max-width: 680px;
      margin: 0 auto;
    }
    .section + .section { border-top: 1px solid var(--border); }
    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: 0.55rem;
    }
    .section h2 {
      font-size: clamp(1.25rem, 4vw, 1.6rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text-main);
      margin: 0 0 1rem;
      line-height: 1.25;
    }
    .section p {
      font-size: 0.97rem;
      line-height: 1.7;
      color: var(--text-muted);
      margin: 0 0 0.85rem;
    }
    .section p:last-child { margin-bottom: 0; }

    .service-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: 1.25rem;
    }
    @media (max-width: 380px) { .service-grid { grid-template-columns: 1fr; } }
    .service-card {
      background: var(--brand-warm);
      border-radius: var(--radius);
      padding: 1rem 1rem 0.9rem;
      border: 1px solid var(--border);
    }
    .service-card-icon { font-size: 1.5rem; margin-bottom: 0.4rem; display: block; }
    .service-card-title { font-size: 0.88rem; font-weight: 700; color: var(--text-main); line-height: 1.3; }

    .check-list {
      list-style: none;
      padding: 0;
      margin: 1.1rem 0 0;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }
    .check-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--text-muted);
    }
    .check-list li::before {
      content: "✓";
      color: var(--brand-accent);
      font-weight: 800;
      flex-shrink: 0;
    }

    .about-card {
      background: var(--brand-warm);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.5rem 1.25rem;
      margin-top: 1rem;
    }
    .about-card p {
      font-size: 0.96rem;
      line-height: 1.7;
      color: var(--text-muted);
      margin: 0 0 0.8rem;
    }
    .about-detail {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.88rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }
    .about-detail strong { color: var(--text-main); }
    .about-detail a { color: var(--brand-accent); font-weight: 700; text-decoration: none; }

    .faq-list {
      display: flex;
      flex-direction: column;
      margin-top: 1.25rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    details.faq-item { border-bottom: 1px solid var(--border); }
    details.faq-item:last-child { border-bottom: none; }
    details.faq-item summary {
      padding: 1rem 1.1rem;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-main);
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      background: var(--brand-white);
      transition: background 0.15s;
    }
    details.faq-item summary::-webkit-details-marker { display: none; }
    details.faq-item summary:hover { background: var(--brand-warm); }
    details.faq-item summary::after {
      content: "+";
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--brand-accent);
      flex-shrink: 0;
      margin-left: 1rem;
    }
    details.faq-item[open] summary::after { content: "−"; }
    .faq-answer {
      padding: 0 1.1rem 1rem;
      font-size: 0.93rem;
      line-height: 1.7;
      color: var(--text-muted);
      background: var(--brand-white);
    }

    .suburb-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 1.1rem;
    }
    .suburb-chip {
      display: inline-block;
      background: var(--brand-warm);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.45rem 0.85rem;
      font-size: 0.84rem;
      font-weight: 600;
      color: var(--text-main);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }
    .suburb-chip:hover {
      background: var(--brand-accent);
      border-color: var(--brand-accent);
      color: #fff;
    }

    .page-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1.1rem;
    }
    .page-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1rem;
      background: var(--brand-warm);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      text-decoration: none;
      font-size: 0.93rem;
      font-weight: 600;
      color: var(--text-main);
      transition: background 0.15s, border-color 0.15s;
    }
    .page-link:hover {
      background: var(--brand-accent);
      border-color: var(--brand-accent);
      color: #fff;
    }
    .page-link span { opacity: 0.5; font-size: 1.1rem; }

    .bottom-cta {
      background: var(--brand-dark);
      color: var(--brand-white);
      padding: 2.5rem 1.25rem;
      text-align: center;
    }
    .bottom-cta h2 {
      font-size: clamp(1.3rem, 4.5vw, 1.7rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--brand-white);
      margin: 0 0 0.6rem;
    }
    .bottom-cta p {
      font-size: 0.95rem;
      color: #908d86;
      margin: 0 0 1.75rem;
      line-height: 1.6;
    }
  </style>

  <section class="hero">
    <span class="hero-eyebrow">Sunbury VIC 3429</span>
    <h1>Chimney Sweeping<br>Sunbury VIC 3429</h1>
    <p class="hero-lead">
      Daves Chimney Sweeping handles chimney and flue cleaning, wood heater servicing and fireplace maintenance for homes across Sunbury and the surrounding north-west corridor.
    </p>
    <p class="hero-sub">
      Sunbury winters can be sharp — if your fireplace or wood heater hasn't had a proper service lately, we make it easy to sort out before the cold arrives.
    </p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

  <div class="trust-bar">
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Serving Sunbury locals
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Owner-operated
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Fast quotes
    </span>
  </div>

  <section class="section">
    <p class="section-label">Our service</p>
    <h2>What We Take Care of in Sunbury</h2>
    <p>
      We clean chimneys, flues and wood heaters for homes throughout Sunbury VIC 3429. Whether you've got an open fireplace, a slow-combustion heater or a built-in wood heater, we'll give it a proper clean and let you know what we find.
    </p>
    <div class="service-grid">
      <div class="service-card">
        <span class="service-card-icon">🔥</span>
        <div class="service-card-title">Chimney Sweeping</div>
      </div>
      <div class="service-card">
        <span class="service-card-icon">🌬️</span>
        <div class="service-card-title">Flue Cleaning</div>
      </div>
      <div class="service-card">
        <span class="service-card-icon">🪵</span>
        <div class="service-card-title">Wood Heater Cleaning</div>
      </div>
      <div class="service-card">
        <span class="service-card-icon">🏠</span>
        <div class="service-card-title">Open Fireplace Service</div>
      </div>
      <div class="service-card">
        <span class="service-card-icon">🐦</span>
        <div class="service-card-title">Blockage Removal</div>
      </div>
      <div class="service-card">
        <span class="service-card-icon">⬛</span>
        <div class="service-card-title">Soot &amp; Ash Removal</div>
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">When to book</p>
    <h2>Reasons Sunbury Homeowners Call Us</h2>
    <p>
      We hear from local homeowners year-round, but most bookings come when one of these sounds familiar:
    </p>
    <ul class="check-list">
      <li>The fireplace smokes back into the room or takes a long time to draw</li>
      <li>There's a persistent burnt smell even when the fire hasn't been lit</li>
      <li>The wood heater isn't burning as efficiently as it used to</li>
      <li>The chimney hasn't been cleaned since moving in — or ever</li>
      <li>Pre-winter prep — getting everything ready before lighting up for the season</li>
      <li>A possible bird nest or debris blocking the flue</li>
    </ul>
  </section>

  <section class="section">
    <p class="section-label">About us</p>
    <h2>Direct, Local, No Fuss</h2>
    <div class="about-card">
      <p>
        Daves Chimney Sweeping is owner-operated. When you call, you're speaking directly to Dave — not a booking line. We service Sunbury VIC 3429 and the surrounding area, including Diggers Rest, Wildwood, Bulla and Clarkefield.
      </p>
      <p>
        We give straight answers, turn up on time, and leave the job properly done. No upselling, no mystery pricing.
      </p>
      <div class="about-detail">
        📞 <strong>Phone:</strong>&nbsp;<a href="tel:0476302729">0476 302 729</a>
      </div>
      <div class="about-detail">
        📍 <strong>Service area:</strong>&nbsp;Sunbury VIC 3429 and surrounds
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">FAQs</p>
    <h2>Questions We Get Asked in Sunbury</h2>
    <div class="faq-list">
      {faqs.map(({ q, a }) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <div class="faq-answer">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="section-label">Nearby areas</p>
    <h2>Other Suburbs We Service Near Sunbury</h2>
    <p>Our work in the north-west corridor extends to several suburbs around Sunbury:</p>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/diggers-rest">Diggers Rest 3427</a>
      <a class="suburb-chip" href="/chimney-sweeping/gisborne">Gisborne 3437</a>
      <a class="suburb-chip" href="/chimney-sweeping/riddells-creek">Riddells Creek 3431</a>
    </div>
  </section>

  <section class="section">
    <p class="section-label">More pages</p>
    <h2>Nearby Service Pages</h2>
    <nav class="page-links" aria-label="Nearby suburb pages">
      <a class="page-link" href="/chimney-sweeping/diggers-rest">
        Chimney Sweeping — Diggers Rest VIC 3427
        <span>›</span>
      </a>
      <a class="page-link" href="/chimney-sweeping/gisborne">
        Chimney Sweeping — Gisborne VIC 3437
        <span>›</span>
      </a>
      <a class="page-link" href="/chimney-sweeping/riddells-creek">
        Chimney Sweeping — Riddells Creek VIC 3431
