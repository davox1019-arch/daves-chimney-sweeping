---
import MainLayout from "../../layouts/MainLayout.astro";

const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["Brighton VIC 3186"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/brighton", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Brighton VIC 3186. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "Brighton", "addressRegion": "VIC", "postalCode": "3186", "addressCountry": "AU"}};
const faqSchema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Do you service Brighton VIC 3186?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 Brighton is part of our bayside Melbourne run. We cover Brighton and surrounding suburbs including Hampton, Cheltenham, Sandringham and Elwood."}}, {"@type": "Question", "name": "Our Brighton home has multiple original fireplaces \u2014 can all be serviced in one visit?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Large multi-fireplace homes are a regular part of our work in Brighton. Let us know the number of chimneys when you book and we will allow the right amount of time. $199 per chimney."}}, {"@type": "Question", "name": "What does the $199 service include?", "acceptedAnswer": {"@type": "Answer", "text": "Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee \u2014 $199 per chimney."}}, {"@type": "Question", "name": "Does the bay air affect chimney condition in Brighton?", "acceptedAnswer": {"@type": "Answer", "text": "It can. Salt-laden air and higher humidity on the bayside can contribute to faster deterioration of lime mortar and flashing around older chimneys. Annual inspection is particularly worthwhile for bay-facing heritage properties."}}, {"@type": "Question", "name": "Is there a call-out fee for Brighton?", "acceptedAnswer": {"@type": "Answer", "text": "No \u2014 $199 flat rate per chimney, complete price."}}]};
const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Brighton VIC 3186", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Brighton VIC 3186", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
const faqs = [
  {q:`Do you service Brighton VIC 3186?`,a:`Yes — Brighton is part of our bayside Melbourne run. We cover Brighton and surrounding suburbs including Hampton, Cheltenham, Sandringham and Elwood.`},
  {q:`Our Brighton home has multiple original fireplaces — can all be serviced in one visit?`,a:`Yes. Large multi-fireplace homes are a regular part of our work in Brighton. Let us know the number of chimneys when you book and we will allow the right amount of time. $199 per chimney.`},
  {q:`What does the $199 service include?`,a:`Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee — $199 per chimney.`},
  {q:`Does the bay air affect chimney condition in Brighton?`,a:`It can. Salt-laden air and higher humidity on the bayside can contribute to faster deterioration of lime mortar and flashing around older chimneys. Annual inspection is particularly worthwhile for bay-facing heritage properties.`},
  {q:`Is there a call-out fee for Brighton?`,a:`No — $199 flat rate per chimney, complete price.`}
];
---

<MainLayout
  title="Chimney Sweep Brighton VIC 3186 — $199 Clean & Inspect"
  description="Chimney sweeping Brighton VIC 3186 — $199 chimney inspection & full clean. Daves Chimney Sweeping: flue cleaning, wood heater service. Call 0476 302 729."
  clusterBase="Melbourne's Bayside Suburbs"
  clusterRegion="Melbourne's bayside suburbs"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Chimney Sweep Brighton 3186</h1>
      <p class="hero-sub">$199 chimney inspection &amp; full clean &mdash; Brighton &amp; surrounds. Owner-operated, no call-out fee, same-week bookings.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:0476302729">Call 0476&nbsp;302&nbsp;729</a>
        <a class="btn-secondary" href="#booking">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <span>&#10003; $199 flat rate</span>
    <span>&#10003; No call-out fee</span>
    <span>&#10003; Same-week bookings</span>
    <span>&#10003; Owner-operated</span>
    <span>&#10003; Brighton &amp; surrounds</span>
  </section>

  <!-- PRICING -->
  <section class="pricing-section" id="pricing">
    <h2>Chimney Sweep Brighton — Pricing</h2>
    <div class="price-card">
      <div class="price-amount">$199</div>
      <div class="price-label">Full chimney inspection &amp; clean</div>
      <ul class="price-includes">
        <li>Full sweep from firebox to pot</li>
        <li>Flue clean &amp; soot removal</li>
        <li>Creosote &amp; blockage check</li>
        <li>Bird nest removal if present</li>
        <li>Verbal condition report</li>
        <li>No call-out fee</li>
      </ul>
      <a class="btn-primary" href="tel:0476302729">Book Now — 0476 302 729</a>
    </div>
  </section>

  <!-- LOCAL KNOWLEDGE -->
  <section class="local-section" id="local">
    <h2>Chimney Sweeping in Brighton</h2>
    <div class="local-box"><p>Brighton is one of Melbourne's most affluent bayside suburbs, developed from the 1850s on the Port Phillip foreshore south of St Kilda and built out through the Victorian, Edwardian and interwar periods as a premier residential address for Melbourne's wealthiest families. The suburb is characterised by large period homes — Victorian mansions and Edwardian residences on generous land along the bay-side streets, alongside substantial interwar and postwar homes set back from the beach. A defining characteristic of Brighton's housing stock is the prevalence of multiple original fireplaces: larger Victorian and Edwardian homes commonly have three to five fireplaces serving the principal rooms and bedrooms, and many have been meticulously maintained by owners who use them regularly. Brighton's bayside position creates a distinctive winter cold pattern: cool southerly airflows off Port Phillip Bay can be sharp and damp through June and July, and bay-facing rooms without a working fireplace can feel very cold on a still winter evening. Professional chimney maintenance is a standard part of property upkeep for many Brighton homes. We service Brighton and the surrounding bayside suburbs regularly and have experience with the large multi-fireplace period homes and Victorian-era heritage chimney systems common throughout the suburb.</p></div>
  </section>

  <!-- SIGNS -->
  <section class="signs-section" id="signs">
    <h2>Signs Your Brighton Chimney Needs Cleaning</h2>
    <ul class="signs-list">
      <li>One or more fireplaces in a large home smoking back when lit</li>
      <li>A chimney or flue that has not been cleaned despite regular winter use</li>
      <li>Heritage lime mortar chimneys that need professional inspection</li>
      <li>Damp or moisture around the fireplace — bay humidity can accelerate flue deterioration</li>
      <li>A recently purchased period home with no record of chimney maintenance</li>
    </ul>
  </section>

  <!-- SERVICES -->
  <section class="services-section" id="services">
    <h2>Chimney Services in Brighton</h2>
    <div class="services-grid">
      <div class="service-card"><h3>Chimney Sweep</h3><p>Full brush sweep from firebox to pot. Soot, creosote and debris removed. Verbal condition report included.</p></div>
      <div class="service-card"><h3>Flue Cleaning</h3><p>Thorough flue clean using professional brushes and equipment. Removes accumulated creosote and restores full draw.</p></div>
      <div class="service-card"><h3>Wood Heater Service</h3><p>Slow combustion heater flue clean and inspection. Baffle check, door seal inspection, full flue swept top to bottom.</p></div>
      <div class="service-card"><h3>Chimney Inspection</h3><p>Visual inspection of firebox, flue, damper, crown and pot. Written report available on request. Included in the $199 service.</p></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews-section" id="reviews">
    <h2>What Brighton Customers Say</h2>
    <div class="reviews-grid">
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Large Victorian home on the Brighton ridge with three original fireplaces. David serviced all three in one visit, was very careful around the heritage fittings, and gave a detailed condition report. Outstanding service.&rdquo;</p><p class="review-author">Victoria H., Brighton</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;We use the main fireplace every night through winter. David cleaned the flue properly and flagged some minor lime mortar deterioration we should monitor. Exactly what you want from a professional chimney sweep.&rdquo;</p><p class="review-author">Christopher B., Brighton</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Inherited this Edwardian home and had no idea of the chimney history. David did a thorough inspection and clean and gave us a clear picture of what each chimney needed. Very professional.&rdquo;</p><p class="review-author">Margaret L., Brighton</p></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <h2>About Dave&rsquo;s Chimney Sweeping</h2>
    <p>Dave&rsquo;s Chimney Sweeping is a local, owner-operated business covering Melbourne's bayside suburbs including Brighton. Dave personally handles every job &mdash; no subcontractors, no call centres. Flat $199 rate per chimney, no hidden fees.</p>
    <a class="btn-secondary" href="tel:0476302729">Call Dave — 0476 302 729</a>
  </section>

  <!-- FAQs -->
  <section class="faq-section" id="faq">
    <h2>Chimney Sweep Brighton — FAQs</h2>
    {faqs.map(f => (
    <details>
      <summary>{f.q}</summary>
      <p>{f.a}</p>
    </details>
    ))}
  </section>

  <!-- BOOKING FORM -->
  <section class="booking-section" id="booking">
    <h2>Book a Chimney Sweep in Brighton</h2>
    <form action="https://formspree.io/f/xdkobvpv" method="POST" class="booking-form">
      <input type="hidden" name="suburb" value="Brighton 3186" />
      <label>Name <input type="text" name="name" required /></label>
      <label>Phone <input type="tel" name="phone" required /></label>
      <label>Email <input type="email" name="email" /></label>
      <label>Message <textarea name="message" rows="3">Chimney sweep enquiry — Brighton 3186</textarea></label>
      <button type="submit" class="btn-primary">Send Enquiry</button>
    </form>
  </section>

  <!-- NEARBY SUBURBS -->
  <section class="nearby-section" id="nearby">
    <h2>Nearby Areas We Service</h2>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/hampton">Hampton 3188</a>
      <a class="suburb-chip" href="/chimney-sweeping/cheltenham">Cheltenham 3192</a>
      <a class="suburb-chip" href="/chimney-sweeping/hampton">Sandringham 3191</a>
      <a class="suburb-chip" href="/chimney-sweeping/st-kilda">Elwood 3184</a>
      <a class="suburb-chip" href="/chimney-sweeping/cheltenham">Beaumaris 3193</a>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo; <a href="/#service-areas">Service Areas</a> &rsaquo; Brighton
  </nav>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <h2>Ready to book your Brighton chimney sweep?</h2>
    <p>$199 flat rate &mdash; no call-out fee &mdash; same-week bookings available.</p>
    <a class="btn-primary" href="tel:0476302729">Call 0476 302 729</a>
  </section>

  <!-- STICKY MOBILE CTA -->
  <a href="tel:0476302729" id="sticky-cta" aria-label="Call or text Dave">
    <span id="sticky-icon">&#128222;</span>
    <span id="sticky-text">Call/Text Dave</span>
  </a>
  <style>
    #sticky-cta{position:fixed;bottom:1.25rem;right:1.25rem;z-index:999;display:flex;align-items:center;gap:.5rem;background:#e07b00;color:#fff;font-weight:700;font-size:1rem;padding:.75rem 1.25rem;border-radius:999px;box-shadow:0 4px 16px rgba(0,0,0,.25);text-decoration:none;transition:opacity .3s;opacity:0;pointer-events:none;}
    #sticky-cta.visible{opacity:1;pointer-events:auto}
    @media(min-width:768px){#sticky-cta{display:none}}
  </style>
  <script is:inline>
    (function(){
      var btn = document.getElementById('sticky-cta');
      var hero = document.querySelector('.hero');
      function check(){
        var threshold = hero ? hero.offsetHeight : 300;
        if(window.scrollY > threshold){ btn.classList.add('visible'); }
        else { btn.classList.remove('visible'); }
      }
      window.addEventListener('scroll', check, {passive:true});
      check();
    })();
  </script>

</MainLayout>
