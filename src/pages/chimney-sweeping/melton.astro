    /* Page links */
    .page-links{display:flex;flex-direction:column;gap:.5rem;margin-top:1rem}
    .page-link{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.1rem;background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);text-decoration:none;font-size:.95rem;font-weight:600;color:var(--tm);transition:background .15s,border-color .15s}
    .page-link:hover{background:var(--ba);border-color:var(--ba);color:#fff}
    .page-link span{opacity:.5;font-size:1.1rem}
    /* Bottom CTA */
    .bottom-cta{background:var(--bd);color:var(--wh);padding:2.8rem 1.25rem;text-align:center}
