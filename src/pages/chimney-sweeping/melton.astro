    .rc{background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:1.1rem 1rem}
    .rc-icon{font-size:1.4rem;display:block;margin-bottom:.4rem}
    .rc-title{font-size:.95rem;font-weight:700;color:var(--tm);margin-bottom:.25rem}
    .rc-desc{font-size:.86rem;line-height:1.55;color:var(--ts)}
