    .trust-bar{background:var(--bm);padding:1rem 1.25rem;display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap}
    .ti{display:flex;align-items:center;gap:.4rem;font-size:.82rem;color:#908d86;font-weight:600;letter-spacing:.03em;text-transform:uppercase}
    .ti svg{flex-shrink:0;color:var(--ba)}
    /* Sections */
    .sec{padding:2.4rem 1.25rem;max-width:720px;margin:0 auto}
    .sec+.sec{border-top:1px solid var(--br)}
    .sl{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ba);margin-bottom:.55rem}
