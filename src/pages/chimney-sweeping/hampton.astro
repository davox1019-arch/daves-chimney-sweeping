---
import MainLayout from "../../layouts/MainLayout.astro";

const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["Hampton VIC 3188"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/hampton", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Hampton VIC 3188. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "Hampton", "addressRegion": "VIC", "postalCode": "3188", "addressCountry": "AU"}};
const faqSchema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Do you service Hampton VIC 3188?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 Hampton is part of our bayside Melbourne run. We cover Hampton and surrounding suburbs including Brighton, Cheltenham, Sandringham and Moorabbin."}}, {"@type": "Question", "name": "We have used our Hampton fireplace every winter for many years without a professional clean \u2014 is that a serious concern?", "acceptedAnswer": {"@type": "Answer", "text": "It can be. Regular use without professional cleaning allows creosote to accumulate in the flue lining, which becomes a fire risk over time. We will clean the full system and give you a clear assessment of the current condition."}}, {"@type": "Question", "name": "What does the $199 service include?", "acceptedAnswer": {"@type": "Answer", "text": "Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee \u2014 $199 per chimney."}}, {"@type": "Question", "name": "How does living near the bay affect chimney maintenance?", "acceptedAnswer": {"@type": "Answer", "text": "Bay-side humidity and salt air can accelerate mortar deterioration and rusting of metal flue components. Annual inspection and cleaning is especially worthwhile for homes close to Port Phillip."}}, {"@type": "Question", "name": "Is there a call-out fee for Hampton?", "acceptedAnswer": {"@type": "Answer", "text": "No \u2014 $199 flat rate per chimney, complete price."}}]};
const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Hampton VIC 3188", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Hampton VIC 3188", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
const faqs = [
  {q:`Do you service Hampton VIC 3188?`,a:`Yes — Hampton is part of our bayside Melbourne run. We cover Hampton and surrounding suburbs including Brighton, Cheltenham, Sandringham and Moorabbin.`},
  {q:`We have used our Hampton fireplace every winter for many years without a professional clean — is that a serious concern?`,a:`It can be. Regular use without professional cleaning allows creosote to accumulate in the flue lining, which becomes a fire risk over time. We will clean the full system and give you a clear assessment of the current condition.`},
  {q:`What does the $199 service include?`,a:`Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee — $199 per chimney.`},
  {q:`How does living near the bay affect chimney maintenance?`,a:`Bay-side humidity and salt air can accelerate mortar deterioration and rusting of metal flue components. Annual inspection and cleaning is especially worthwhile for homes close to Port Phillip.`},
  {q:`Is there a call-out fee for Hampton?`,a:`No — $199 flat rate per chimney, complete price.`}
];
---

<MainLayout
  title="Chimney Sweep Hampton VIC 3188 — $199 Clean & Inspect"
  description="Chimney sweeping Hampton VIC 3188 — $199 chimney inspection & full clean. Daves Chimney Sweeping: flue cleaning, wood heater service. Call 0476 302 729."
  clusterBase="Melbourne's Bayside Suburbs"
  clusterRegion="Melbourne's bayside suburbs"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Chimney Sweep Hampton 3188</h1>
      <p class="hero-sub">$199 chimney inspection &amp; full clean &mdash; Hampton &amp; surrounds. Owner-operated, no call-out fee, same-week bookings.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:0476302729">Call 0476&nbsp;302&nbsp;729</a>
        <a class="btn-secondary" href="#booking">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <span>&#10003; $199 flat rate</span>
    <span>&#10003; No call-out fee</span>
    <span>&#10003; Same-week bookings</span>
    <span>&#10003; Owner-operated</span>
    <span>&#10003; Hampton &amp; surrounds</span>
  </section>

  <!-- PRICING -->
  <section class="pricing-section" id="pricing">
    <h2>Chimney Sweep Hampton — Pricing</h2>
    <div class="price-card">
      <div class="price-amount">$199</div>
      <div class="price-label">Full chimney inspection &amp; clean</div>
      <ul class="price-includes">
        <li>Full sweep from firebox to pot</li>
        <li>Flue clean &amp; soot removal</li>
        <li>Creosote &amp; blockage check</li>
        <li>Bird nest removal if present</li>
        <li>Verbal condition report</li>
        <li>No call-out fee</li>
      </ul>
      <a class="btn-primary" href="tel:0476302729">Book Now — 0476 302 729</a>
    </div>
  </section>

  <!-- LOCAL KNOWLEDGE -->
  <section class="local-section" id="local">
    <h2>Chimney Sweeping in Hampton</h2>
    <div class="local-box"><p>Hampton is an established bayside suburb south of Brighton, developed primarily through the interwar and postwar periods as the bayside rail corridor attracted steady residential growth. The suburb's housing stock is a genuine mix: the streets closest to the beach and the Bay Street retail strip contain substantial interwar bungalows and cottages from the 1920s through the 1940s, while the eastern end of Hampton transitions to postwar brick veneer homes from the 1950s through the 1970s. A high proportion of Hampton's interwar homes retain their original fireplaces — typically a single fireplace in the main living room, occasionally with a second in the front bedroom — and the original chimney and flue systems have often been in continuous use since the home was built. Hampton's position on the Port Phillip foreshore means bay southerlies push cold damp air through the suburb through winter, and the combination of bay humidity and cold air makes a working fireplace essential comfort in many homes. We service Hampton and the surrounding bayside suburbs regularly and are familiar with the interwar bungalow chimney systems and postwar brick-veneer flue configurations common throughout the suburb.</p></div>
  </section>

  <!-- SIGNS -->
  <section class="signs-section" id="signs">
    <h2>Signs Your Hampton Chimney Needs Cleaning</h2>
    <ul class="signs-list">
      <li>Smoke pushing back into the room or settling in the house when the fire is lit</li>
      <li>A damp or musty smell from the fireplace during wet weather</li>
      <li>Soot marks around the firebox that weren't there previously</li>
      <li>A fireplace in regular use for many winters without a professional clean</li>
      <li>A slow draw — the fire is hard to get going and maintain</li>
    </ul>
  </section>

  <!-- SERVICES -->
  <section class="services-section" id="services">
    <h2>Chimney Services in Hampton</h2>
    <div class="services-grid">
      <div class="service-card"><h3>Chimney Sweep</h3><p>Full brush sweep from firebox to pot. Soot, creosote and debris removed. Verbal condition report included.</p></div>
      <div class="service-card"><h3>Flue Cleaning</h3><p>Thorough flue clean using professional brushes and equipment. Removes accumulated creosote and restores full draw.</p></div>
      <div class="service-card"><h3>Wood Heater Service</h3><p>Slow combustion heater flue clean and inspection. Baffle check, door seal inspection, full flue swept top to bottom.</p></div>
      <div class="service-card"><h3>Chimney Inspection</h3><p>Visual inspection of firebox, flue, damper, crown and pot. Written report available on request. Included in the $199 service.</p></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews-section" id="reviews">
    <h2>What Hampton Customers Say</h2>
    <div class="reviews-grid">
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Interwar bungalow near the beach. David swept the flue, found a partially blocked pot and gave a clear report on the full chimney. Fireplace has never drawn better. Will use every year.&rdquo;</p><p class="review-author">Graham A., Hampton</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;We have lived here for twelve years and this was the first professional clean the chimney has had. David found creosote build-up and a cracked flue tile. Really glad we called when we did.&rdquo;</p><p class="review-author">Fiona C., Hampton</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Quick response, turned up on time, did a thorough job. David explained everything he found and left no mess. Excellent service — exactly what you want before winter.&rdquo;</p><p class="review-author">Stephen M., Hampton</p></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <h2>About Dave&rsquo;s Chimney Sweeping</h2>
    <p>Dave&rsquo;s Chimney Sweeping is a local, owner-operated business covering Melbourne's bayside suburbs including Hampton. Dave personally handles every job &mdash; no subcontractors, no call centres. Flat $199 rate per chimney, no hidden fees.</p>
    <a class="btn-secondary" href="tel:0476302729">Call Dave — 0476 302 729</a>
  </section>

  <!-- FAQs -->
  <section class="faq-section" id="faq">
    <h2>Chimney Sweep Hampton — FAQs</h2>
    {faqs.map(f => (
    <details>
      <summary>{f.q}</summary>
      <p>{f.a}</p>
    </details>
    ))}
  </section>

  <!-- BOOKING FORM -->
  <section class="booking-section" id="booking">
    <h2>Book a Chimney Sweep in Hampton</h2>
    <form action="https://formspree.io/f/xdkobvpv" method="POST" class="booking-form">
      <input type="hidden" name="suburb" value="Hampton 3188" />
      <label>Name <input type="text" name="name" required /></label>
      <label>Phone <input type="tel" name="phone" required /></label>
      <label>Email <input type="email" name="email" /></label>
      <label>Message <textarea name="message" rows="3">Chimney sweep enquiry — Hampton 3188</textarea></label>
      <button type="submit" class="btn-primary">Send Enquiry</button>
    </form>
  </section>

  <!-- NEARBY SUBURBS -->
  <section class="nearby-section" id="nearby">
    <h2>Nearby Areas We Service</h2>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/brighton">Brighton 3186</a>
      <a class="suburb-chip" href="/chimney-sweeping/cheltenham">Cheltenham 3192</a>
      <a class="suburb-chip" href="/chimney-sweeping/hampton">Sandringham 3191</a>
      <a class="suburb-chip" href="/chimney-sweeping/cheltenham">Beaumaris 3193</a>
      <a class="suburb-chip" href="/chimney-sweeping/cheltenham">Moorabbin 3189</a>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo; <a href="/#service-areas">Service Areas</a> &rsaquo; Hampton
  </nav>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <h2>Ready to book your Hampton chimney sweep?</h2>
    <p>$199 flat rate &mdash; no call-out fee &mdash; same-week bookings available.</p>
    <a class="btn-primary" href="tel:0476302729">Call 0476 302 729</a>
  </section>

  <!-- STICKY MOBILE CTA -->
  <a href="tel:0476302729" id="sticky-cta" aria-label="Call or text Dave">
    <span id="sticky-icon">&#128222;</span>
    <span id="sticky-text">Call/Text Dave</span>
  </a>
  <style>
    #sticky-cta{position:fixed;bottom:1.25rem;right:1.25rem;z-index:999;display:flex;align-items:center;gap:.5rem;background:#e07b00;color:#fff;font-weight:700;font-size:1rem;padding:.75rem 1.25rem;border-radius:999px;box-shadow:0 4px 16px rgba(0,0,0,.25);text-decoration:none;transition:opacity .3s;opacity:0;pointer-events:none;}
    #sticky-cta.visible{opacity:1;pointer-events:auto}
    @media(min-width:768px){#sticky-cta{display:none}}
  </style>
  <script is:inline>
    (function(){
      var btn = document.getElementById('sticky-cta');
      var hero = document.querySelector('.hero');
      function check(){
        var threshold = hero ? hero.offsetHeight : 300;
        if(window.scrollY > threshold){ btn.classList.add('visible'); }
        else { btn.classList.remove('visible'); }
      }
      window.addEventListener('scroll', check, {passive:true});
      check();
    })();
  </script>

</MainLayout>
