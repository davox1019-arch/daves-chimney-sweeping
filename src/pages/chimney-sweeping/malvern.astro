---
import MainLayout from "../../layouts/MainLayout.astro";

const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["Malvern VIC 3144"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/malvern", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Malvern VIC 3144. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "Malvern", "addressRegion": "VIC", "postalCode": "3144", "addressCountry": "AU"}};
const faqSchema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Do you service Malvern VIC 3144?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 Malvern is part of our inner eastern Melbourne run. We cover Malvern and surrounding suburbs including Hawthorn, Camberwell, Glen Iris and South Yarra."}}, {"@type": "Question", "name": "Our Malvern home has four original fireplaces \u2014 can you service all of them in one visit?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Large multi-fireplace homes are something we handle regularly in Malvern. Let us know the number of chimneys when you book and we will allocate the right amount of time. $199 per chimney."}}, {"@type": "Question", "name": "What does the $199 service include?", "acceptedAnswer": {"@type": "Answer", "text": "Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee \u2014 $199 per chimney."}}, {"@type": "Question", "name": "How often should the chimneys in a large Malvern period home be cleaned?", "acceptedAnswer": {"@type": "Answer", "text": "Annually for each fireplace that is regularly used. Heritage lime mortar chimneys in large period homes benefit from consistent annual inspection \u2014 catching small issues early is far more cost-effective than addressing structural problems later."}}, {"@type": "Question", "name": "Is there a call-out fee for Malvern?", "acceptedAnswer": {"@type": "Answer", "text": "No \u2014 $199 flat rate per chimney, complete price."}}]};
const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Malvern VIC 3144", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Malvern VIC 3144", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
const faqs = [
  {q:`Do you service Malvern VIC 3144?`,a:`Yes — Malvern is part of our inner eastern Melbourne run. We cover Malvern and surrounding suburbs including Hawthorn, Camberwell, Glen Iris and South Yarra.`},
  {q:`Our Malvern home has four original fireplaces — can you service all of them in one visit?`,a:`Yes. Large multi-fireplace homes are something we handle regularly in Malvern. Let us know the number of chimneys when you book and we will allocate the right amount of time. $199 per chimney.`},
  {q:`What does the $199 service include?`,a:`Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee — $199 per chimney.`},
  {q:`How often should the chimneys in a large Malvern period home be cleaned?`,a:`Annually for each fireplace that is regularly used. Heritage lime mortar chimneys in large period homes benefit from consistent annual inspection — catching small issues early is far more cost-effective than addressing structural problems later.`},
  {q:`Is there a call-out fee for Malvern?`,a:`No — $199 flat rate per chimney, complete price.`}
];
---

<MainLayout
  title="Chimney Sweep Malvern VIC 3144 — $199 Clean & Inspect"
  description="Chimney sweeping Malvern VIC 3144 — $199 chimney inspection & full clean. Daves Chimney Sweeping: flue cleaning, wood heater service. Call 0476 302 729."
  clusterBase="Melbourne's Inner Eastern Suburbs"
  clusterRegion="Melbourne's inner eastern suburbs"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Chimney Sweep Malvern 3144</h1>
      <p class="hero-sub">$199 chimney inspection &amp; full clean &mdash; Malvern &amp; surrounds. Owner-operated, no call-out fee, same-week bookings.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:0476302729">Call 0476&nbsp;302&nbsp;729</a>
        <a class="btn-secondary" href="#booking">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <span>&#10003; $199 flat rate</span>
    <span>&#10003; No call-out fee</span>
    <span>&#10003; Same-week bookings</span>
    <span>&#10003; Owner-operated</span>
    <span>&#10003; Malvern &amp; surrounds</span>
  </section>

  <!-- PRICING -->
  <section class="pricing-section" id="pricing">
    <h2>Chimney Sweep Malvern — Pricing</h2>
    <div class="price-card">
      <div class="price-amount">$199</div>
      <div class="price-label">Full chimney inspection &amp; clean</div>
      <ul class="price-includes">
        <li>Full sweep from firebox to pot</li>
        <li>Flue clean &amp; soot removal</li>
        <li>Creosote &amp; blockage check</li>
        <li>Bird nest removal if present</li>
        <li>Verbal condition report</li>
        <li>No call-out fee</li>
      </ul>
      <a class="btn-primary" href="tel:0476302729">Book Now — 0476 302 729</a>
    </div>
  </section>

  <!-- LOCAL KNOWLEDGE -->
  <section class="local-section" id="local">
    <h2>Chimney Sweeping in Malvern</h2>
    <div class="local-box"><p>Malvern is one of Melbourne's most prestigious inner eastern suburbs, developed from the 1880s through the interwar period on the high ground between the Yarra valley and the Monash Freeway corridor. The suburb is characterised by substantial Victorian and Edwardian homes — large single-storey and double-storey period residences on generous land, many of which were built as significant family homes by Melbourne's professional class. A defining feature of Malvern's housing stock is the prevalence of multiple original fireplaces: it is common for a larger Malvern period home to have three, four or even five fireplaces serving the principal bedrooms and reception rooms, each with its own dedicated flue. Many of these homes are maintained to a very high standard by owners who value the original features, and chimney maintenance is typically part of the regular property upkeep cycle. Malvern's elevated position creates a distinctive winter cold pattern: westerly winds across the inner east can be sharp on the exposed ridge, and the combination of a large period home and genuine winter cold makes properly maintained fireplaces an important amenity. We service Malvern regularly and have experience with the large multi-fireplace period homes, Victorian-era heritage chimney systems and multiple-stack configurations common in the suburb.</p></div>
  </section>

  <!-- SIGNS -->
  <section class="signs-section" id="signs">
    <h2>Signs Your Malvern Chimney Needs Cleaning</h2>
    <ul class="signs-list">
      <li>One or more of several fireplaces smoking back when lit</li>
      <li>A flue or chimney that hasn't been cleaned despite regular use through winter</li>
      <li>Soot or smoke staining on period cornicing or plasterwork near the fireplace</li>
      <li>A fireplace in a heritage-listed property that needs careful professional attention</li>
      <li>A chimney pot or stack that appears damaged or deteriorated from outside</li>
    </ul>
  </section>

  <!-- SERVICES -->
  <section class="services-section" id="services">
    <h2>Chimney Services in Malvern</h2>
    <div class="services-grid">
      <div class="service-card"><h3>Chimney Sweep</h3><p>Full brush sweep from firebox to pot. Soot, creosote and debris removed. Verbal condition report included.</p></div>
      <div class="service-card"><h3>Flue Cleaning</h3><p>Thorough flue clean using professional brushes and equipment. Removes accumulated creosote and restores full draw.</p></div>
      <div class="service-card"><h3>Wood Heater Service</h3><p>Slow combustion heater flue clean and inspection. Baffle check, door seal inspection, full flue swept top to bottom.</p></div>
      <div class="service-card"><h3>Chimney Inspection</h3><p>Visual inspection of firebox, flue, damper, crown and pot. Written report available on request. Included in the $199 service.</p></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews-section" id="reviews">
    <h2>What Malvern Customers Say</h2>
    <div class="reviews-grid">
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Large Edwardian home with four original fireplaces. David swept all four chimneys in a single visit, worked carefully around the original tiling and fittings, and gave a detailed report on each one. Excellent professional.&rdquo;</p><p class="review-author">Catherine P., Malvern</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Heritage property on the Malvern ridge. David found deteriorating lime mortar in one stack and a partial blockage in another. Really glad we had the full inspection done before winter.&rdquo;</p><p class="review-author">Robert S., Malvern</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;We use two fireplaces regularly through winter. David cleaned both flues and inspected the full chimney system. Professional, thorough and very reasonably priced at $199 per chimney.&rdquo;</p><p class="review-author">Louise F., Malvern</p></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <h2>About Dave&rsquo;s Chimney Sweeping</h2>
    <p>Dave&rsquo;s Chimney Sweeping is a local, owner-operated business covering Melbourne's inner eastern suburbs including Malvern. Dave personally handles every job &mdash; no subcontractors, no call centres. Flat $199 rate per chimney, no hidden fees.</p>
    <a class="btn-secondary" href="tel:0476302729">Call Dave — 0476 302 729</a>
  </section>

  <!-- FAQs -->
  <section class="faq-section" id="faq">
    <h2>Chimney Sweep Malvern — FAQs</h2>
    {faqs.map(f => (
    <details>
      <summary>{f.q}</summary>
      <p>{f.a}</p>
    </details>
    ))}
  </section>

  <!-- BOOKING FORM -->
  <section class="booking-section" id="booking">
    <h2>Book a Chimney Sweep in Malvern</h2>
    <form action="https://formspree.io/f/xdkobvpv" method="POST" class="booking-form">
      <input type="hidden" name="suburb" value="Malvern 3144" />
      <label>Name <input type="text" name="name" required /></label>
      <label>Phone <input type="tel" name="phone" required /></label>
      <label>Email <input type="email" name="email" /></label>
      <label>Message <textarea name="message" rows="3">Chimney sweep enquiry — Malvern 3144</textarea></label>
      <button type="submit" class="btn-primary">Send Enquiry</button>
    </form>
  </section>

  <!-- NEARBY SUBURBS -->
  <section class="nearby-section" id="nearby">
    <h2>Nearby Areas We Service</h2>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/hawthorn">Hawthorn 3122</a>
      <a class="suburb-chip" href="/chimney-sweeping/camberwell">Camberwell 3124</a>
      <a class="suburb-chip" href="/chimney-sweeping/south-yarra">South Yarra 3141</a>
      <a class="suburb-chip" href="/chimney-sweeping/glen-iris">Glen Iris 3146</a>
      <a class="suburb-chip" href="/chimney-sweeping/south-yarra">Toorak 3142</a>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo; <a href="/#service-areas">Service Areas</a> &rsaquo; Malvern
  </nav>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <h2>Ready to book your Malvern chimney sweep?</h2>
    <p>$199 flat rate &mdash; no call-out fee &mdash; same-week bookings available.</p>
    <a class="btn-primary" href="tel:0476302729">Call 0476 302 729</a>
  </section>

  <!-- STICKY MOBILE CTA -->
  <a href="tel:0476302729" id="sticky-cta" aria-label="Call or text Dave">
    <span id="sticky-icon">&#128222;</span>
    <span id="sticky-text">Call/Text Dave</span>
  </a>
  <style>
    #sticky-cta{position:fixed;bottom:1.25rem;right:1.25rem;z-index:999;display:flex;align-items:center;gap:.5rem;background:#e07b00;color:#fff;font-weight:700;font-size:1rem;padding:.75rem 1.25rem;border-radius:999px;box-shadow:0 4px 16px rgba(0,0,0,.25);text-decoration:none;transition:opacity .3s;opacity:0;pointer-events:none;}
    #sticky-cta.visible{opacity:1;pointer-events:auto}
    @media(min-width:768px){#sticky-cta{display:none}}
  </style>
  <script is:inline>
    (function(){
      var btn = document.getElementById('sticky-cta');
      var hero = document.querySelector('.hero');
      function check(){
        var threshold = hero ? hero.offsetHeight : 300;
        if(window.scrollY > threshold){ btn.classList.add('visible'); }
        else { btn.classList.remove('visible'); }
      }
      window.addEventListener('scroll', check, {passive:true});
      check();
    })();
  </script>

</MainLayout>
