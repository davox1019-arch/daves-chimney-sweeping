const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Officer VIC 3809", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Officer VIC 3809", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
