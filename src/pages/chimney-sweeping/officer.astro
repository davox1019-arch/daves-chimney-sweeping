      <a class="suburb-chip" href="/chimney-sweeping/pakenham">Pakenham 3810</a>
      <a class="suburb-chip" href="/chimney-sweeping/berwick">Berwick 3806</a>
      <a class="suburb-chip" href="/chimney-sweeping/officer">Beaconsfield 3807</a>
