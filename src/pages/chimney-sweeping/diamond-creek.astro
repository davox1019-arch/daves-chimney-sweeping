---
import MainLayout from "../../layouts/MainLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61476302729",
  areaServed: ["Diamond Creek VIC 3089","Eltham VIC 3095","Greensborough VIC 3088","Hurstbridge VIC 3099"],
  url: "https://daveschimneysweeping.com.au/chimney-sweeping/diamond-creek",
  description: "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Diamond Creek VIC 3089.",
  address: { "@type": "PostalAddress", addressLocality: "Diamond Creek", addressRegion: "VIC", postalCode: "3089", addressCountry: "AU" }
};

const faqs = [
  { q: "Is Diamond Creek postcode 3089?", a: "Yes — Diamond Creek VIC 3089. We cover the whole suburb and nearby areas including Yarrambat and St Helena." },
  { q: "My fireplace has never been professionally cleaned — is that a problem?", a: "It's common, especially in homes that have changed hands a few times. We'll assess it on the day and let you know what we find before doing any work." },
  { q: "How do I know if it's a chimney sweep I need or a flue clean?", a: "Most of the time it's both — chimney sweeping and flue cleaning are typically done together as they're part of the same system. We cover the full job in one visit." },
  { q: "Can you clean a wood heater installed in a Diamond Creek home?", a: "Yes. Wood heaters and slow combustion units are one of the most common setups we service in the Diamond Creek area." },
  { q: "What time of year is best to book?", a: "Autumn is popular — before you start lighting fires for winter. But we work year-round so you don't need to wait for a particular window." }
];
---

<MainLayout
  title="Chimney Sweeping Diamond Creek VIC 3089 | Daves Chimney Sweeping"
  description="Chimney sweeping in Diamond Creek VIC 3089. Local flue cleaning, wood heater servicing and fireplace maintenance. Owner-operated. Call 0476 302 729."
  clusterBase="Eltham"
  clusterRegion="Eltham and surrounding north-east suburbs"
  homeHref="/"
  servicePageHref="/"
  servicePageLabel="Chimney Sweeping Melbourne"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>

  <style>
    :root{--bd:#1a1a18;--bm:#2c2c29;--ba:#c8500a;--bw:#f5f0e8;--wh:#ffffff;--tm:#1a1a18;--ts:#5a5a54;--br:#e2ddd4;--rad:10px}
    .hero{background:var(--bd);color:var(--wh);padding:2.8rem 1.25rem 2.5rem;text-align:center}
    .hero-eyebrow{display:inline-block;background:var(--ba);color:#fff;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.3rem .85rem;border-radius:20px;margin-bottom:1.1rem}
    .hero h1{font-size:clamp(1.65rem,5vw,2.3rem);font-weight:800;line-height:1.15;letter-spacing:-.02em;margin:0 0 1rem;color:var(--wh)}
    .hero-lead{font-size:1rem;line-height:1.65;color:#c8c5be;margin:0 auto .75rem;max-width:500px}
    .hero-sub{font-size:.93rem;line-height:1.6;color:#6e6b64;max-width:500px;margin:0 auto 2rem}
    .btn-row{display:flex;flex-direction:column;gap:.75rem;align-items:center}
    .btn{display:inline-block;padding:.95rem 2rem;border-radius:var(--rad);font-size:1rem;font-weight:700;text-decoration:none;text-align:center;width:100%;max-width:320px;transition:opacity .15s}
    .btn:hover{opacity:.88}
    .btn-call{background:var(--ba);color:#fff;font-size:1.1rem}
    .btn-quote{background:transparent;border:2px solid #4a4a44;color:#c8c5be}
    .trust-bar{background:var(--bm);padding:.95rem 1.25rem;display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap}
    .ti{display:flex;align-items:center;gap:.4rem;font-size:.8rem;color:#908d86;font-weight:600;letter-spacing:.03em;text-transform:uppercase}
    .ti svg{flex-shrink:0;color:var(--ba)}
    .sec{padding:2.2rem 1.25rem;max-width:700px;margin:0 auto}
    .sec+.sec{border-top:1px solid var(--br)}
    .sec-label{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ba);margin-bottom:.55rem}
    .sec h2{font-size:clamp(1.25rem,4vw,1.65rem);font-weight:800;letter-spacing:-.02em;color:var(--tm);margin:0 0 1rem;line-height:1.2}
    .sec p{font-size:.97rem;line-height:1.72;color:var(--ts);margin:0 0 .85rem}
    .sec p:last-child{margin-bottom:0}

    /* Step list */
    .step-list{list-style:none;padding:0;margin:1.25rem 0 0;display:flex;flex-direction:column;gap:.85rem}
    .step-item{display:flex;gap:.9rem;align-items:flex-start}
    .step-num{flex-shrink:0;width:2rem;height:2rem;background:var(--ba);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:800}
    .step-text{font-size:.95rem;line-height:1.6;color:var(--ts);padding-top:.2rem}
    .step-text strong{color:var(--tm)}

    /* Why cards */
    .why-list{display:flex;flex-direction:column;gap:.65rem;margin-top:1.1rem}
    .why-card{display:flex;gap:.85rem;background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:.9rem 1rem;align-items:flex-start}
    .why-icon{font-size:1.2rem;flex-shrink:0;margin-top:.1rem}
    .why-body{}
    .why-title{font-size:.88rem;font-weight:700;color:var(--tm);margin-bottom:.2rem}
    .why-desc{font-size:.82rem;line-height:1.5;color:var(--ts)}

    /* About */
    .about-card{background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:1.5rem 1.25rem;margin-top:1rem}
    .about-card p{font-size:.96rem;line-height:1.7;color:var(--ts);margin:0 0 .8rem}
    .about-card p:last-child{margin-bottom:0}
    .arow{display:flex;align-items:center;gap:.5rem;font-size:.88rem;color:var(--ts);margin-top:.55rem}
    .arow strong{color:var(--tm)}
    .arow a{color:var(--ba);font-weight:700;text-decoration:none}

    /* Booking form */
    .form-wrap{background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);padding:1.5rem 1.25rem;margin-top:1rem}
    .form-wrap h3{font-size:1.05rem;font-weight:800;color:var(--tm);margin:0 0 .3rem}
    .form-wrap .form-sub{font-size:.85rem;color:var(--ts);margin:0 0 1.1rem}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:.65rem}
    @media(max-width:480px){.form-grid{grid-template-columns:1fr}}
    .field{display:flex;flex-direction:column;gap:.3rem}
    .field.full{grid-column:1/-1}
    .field label{font-size:.78rem;font-weight:700;color:var(--tm);letter-spacing:.02em;text-transform:uppercase}
    .field input,.field select,.field textarea{width:100%;border:1.5px solid var(--br);border-radius:8px;padding:.65rem .8rem;font-size:.9rem;background:var(--wh);color:var(--tm);font-family:inherit;transition:border-color .15s;outline:none}
    .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--ba)}
    .field textarea{resize:vertical;min-height:80px}
    .form-submit{display:block;width:100%;margin-top:.85rem;background:var(--ba);color:#fff;border:none;padding:.9rem;border-radius:var(--rad);font-size:1rem;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .15s}
    .form-submit:hover{opacity:.88}

    /* FAQ */
    .faq-list{margin-top:1.25rem;border:1px solid var(--br);border-radius:var(--rad);overflow:hidden}
    details.faq-item{border-bottom:1px solid var(--br)}
    details.faq-item:last-child{border-bottom:none}
    details.faq-item summary{padding:1rem 1.1rem;font-size:.95rem;font-weight:700;color:var(--tm);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;user-select:none;background:var(--wh);transition:background .15s;gap:1rem}
    details.faq-item summary::-webkit-details-marker{display:none}
    details.faq-item summary:hover{background:var(--bw)}
    details.faq-item summary::after{content:"+";font-size:1.3rem;font-weight:400;color:var(--ba);flex-shrink:0}
    details.faq-item[open] summary::after{content:"−"}
    .faq-answer{padding:0 1.1rem 1rem;font-size:.93rem;line-height:1.7;color:var(--ts);background:var(--wh)}

    /* Suburb chips */
    .suburb-chips{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1rem}
    .suburb-chip{display:inline-block;background:var(--bw);border:1px solid var(--br);border-radius:6px;padding:.4rem .8rem;font-size:.82rem;font-weight:600;color:var(--tm);text-decoration:none;transition:background .15s,border-color .15s}
    .suburb-chip:hover{background:var(--ba);border-color:var(--ba);color:#fff}

    /* Page links */
    .page-links{display:flex;flex-direction:column;gap:.5rem;margin-top:1rem}
    .page-link{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1rem;background:var(--bw);border:1px solid var(--br);border-radius:var(--rad);text-decoration:none;font-size:.92rem;font-weight:600;color:var(--tm);transition:background .15s,border-color .15s}
    .page-link:hover{background:var(--ba);border-color:var(--ba);color:#fff}
    .page-link span{opacity:.5;font-size:1.1rem}

    .bottom-cta{background:var(--bd);color:var(--wh);padding:2.5rem 1.25rem;text-align:center}
    .bottom-cta h2{font-size:clamp(1.3rem,4.5vw,1.7rem);font-weight:800;letter-spacing:-.02em;color:var(--wh);margin:0 0 .6rem}
    .bottom-cta p{font-size:.95rem;color:#6e6b64;margin:0 0 1.75rem;line-height:1.6}
  </style>

  <section class="hero">
    <span class="hero-eyebrow">Diamond Creek VIC 3089</span>
    <h1>Chimney Sweeping<br>Diamond Creek VIC 3089</h1>
    <p class="hero-lead">
      Diamond Creek homes rely on fireplaces and wood heaters through Victoria's cold winters. Regular chimney and flue cleaning keeps them running properly — and that's what Daves Chimney Sweeping does for locals across Diamond Creek 3089.
    </p>
    <p class="hero-sub">Local owner-operated service. Call Dave directly — no middlemen, no delays.</p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="#quote">Get a Quote</a>
    </div>
  </section>

  <div class="trust-bar">
    <span class="ti"><svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Diamond Creek locals</span>
    <span class="ti"><svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Owner-operated</span>
    <span class="ti"><svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>All heater types</span>
  </div>

  <!-- HOW IT WORKS -->
  <section class="sec">
    <p class="sec-label">How it works</p>
    <h2>What Happens During a Diamond Creek Chimney Clean</h2>
    <p>We keep the process simple and tidy. Here's what a typical job in Diamond Creek looks like:</p>
    <ol class="step-list">
      <li class="step-item">
        <span class="step-num">1</span>
        <span class="step-text"><strong>We lay dust sheets</strong> — the floor and surrounds are protected before we touch anything.</span>
      </li>
      <li class="step-item">
        <span class="step-num">2</span>
        <span class="step-text"><strong>Firebox and flue cleaned</strong> — soot, ash and creosote removed from the firebox through to the chimney stack.</span>
      </li>
      <li class="step-item">
        <span class="step-num">3</span>
        <span class="step-text"><strong>Blockages checked and cleared</strong> — bird nests, debris or any obstructions dealt with in the same visit.</span>
      </li>
      <li class="step-item">
        <span class="step-num">4</span>
        <span class="step-text"><strong>We tell you what we found</strong> — honest assessment of the system's condition, no upselling.</span>
      </li>
      <li class="step-item">
        <span class="step-num">5</span>
        <span class="step-text"><strong>All debris removed</strong> — we take everything with us. Job left tidy.</span>
      </li>
    </ol>
  </section>

  <!-- WHY BOOK -->
  <section class="sec">
    <p class="sec-label">Why homeowners call</p>
    <h2>Common Reasons Diamond Creek Residents Book</h2>
    <div class="why-list">
      <div class="why-card"><span class="why-icon">📅</span><div class="why-body"><div class="why-title">Pre-winter preparation</div><div class="why-desc">Getting the chimney sorted in autumn before the heating season is the most common reason.</div></div></div>
      <div class="why-card"><span class="why-icon">🌫️</span><div class="why-body"><div class="why-title">Smoke drifting inside</div><div class="why-desc">Reverse draft is almost always caused by a sooted or partially blocked flue.</div></div></div>
      <div class="why-card"><span class="why-icon">🏡</span><div class="why-body"><div class="why-title">New home, unknown history</div><div class="why-desc">Moving into a place with an existing fireplace or wood heater — wise to check it first.</div></div></div>
      <div class="why-card"><span class="why-icon">⬛</span><div class="why-body"><div class="why-title">Visible soot buildup</div><div class="why-desc">Heavy black soot around the firebox is a straightforward sign it's time for a clean.</div></div></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="sec">
    <p class="sec-label">About us</p>
    <h2>Dealing Direct — No Franchise, No Runaround</h2>
    <div class="about-card">
      <p>Daves Chimney Sweeping is owner-operated. Dave covers Diamond Creek VIC 3089 and the surrounding north-east suburbs as part of a regular local run.</p>
      <p>You call, you talk to Dave, he turns up, he does the job. That's the whole model — and it means you actually get answers when you call, not a booking queue.</p>
      <div class="arow">📞 <strong>Phone:</strong>&nbsp;<a href="tel:0476302729">0476 302 729</a></div>
      <div class="arow">📍 <strong>Serving:</strong>&nbsp;Diamond Creek VIC 3089 and surrounds</div>
    </div>
  </section>

  <!-- BOOKING FORM -->
  <section class="sec" id="quote">
    <p class="sec-label">Book now</p>
    <h2>Request a Quote for Diamond Creek</h2>
    <div class="form-wrap">
      <h3>Quick Quote — Diamond Creek</h3>
      <p class="form-sub">Send your details and we'll get back to you with a straight price.</p>
      <form action="https://formspree.io/f/maqlwkpr" method="POST">
        <input type="hidden" name="suburb" value="Diamond Creek VIC 3089" />
        <div class="form-grid">
          <div class="field"><label for="name-dc">Full Name</label><input id="name-dc" type="text" name="name" required placeholder="Your name" /></div>
          <div class="field"><label for="phone-dc">Phone</label><input id="phone-dc" type="tel" name="phone" required placeholder="0400 000 000" /></div>
          <div class="field"><label for="email-dc">Email</label><input id="email-dc" type="email" name="email" placeholder="Optional" /></div>
          <div class="field"><label for="svc-dc">Service</label>
            <select id="svc-dc" name="service" required>
              <option value="">Select…</option>
              <option>Chimney Sweeping</option>
              <option>Flue Cleaning</option>
              <option>Wood Heater Cleaning</option>
              <option>Fireplace Cleaning</option>
              <option>Blockage / Nest Removal</option>
              <option>Not sure — need advice</option>
            </select>
          </div>
          <div class="field full"><label for="msg-dc">Details</label><textarea id="msg-dc" name="message" placeholder="Type of system, when last serviced, anything useful…"></textarea></div>
        </div>
        <button type="submit" class="form-submit">Send Quote Request</button>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="sec">
    <p class="sec-label">FAQs</p>
    <h2>Diamond Creek Chimney Sweeping — FAQs</h2>
    <div class="faq-list">
      {faqs.map(({q,a}) => (
        <details class="faq-item"><summary>{q}</summary><div class="faq-answer">{a}</div></details>
      ))}
    </div>
  </section>

  <!-- NEARBY -->
  <section class="sec">
    <p class="sec-label">Nearby areas</p>
    <h2>Suburbs Around Diamond Creek We Also Service</h2>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/eltham">Eltham 3095</a>
      <a class="suburb-chip" href="/chimney-sweeping/eltham-north">Eltham North 3095</a>
      <a class="suburb-chip" href="/chimney-sweeping/greensborough">Greensborough 3088</a>
      <a class="suburb-chip" href="/chimney-sweeping/hurstbridge">Hurstbridge 3099</a>
      <a class="suburb-chip" href="/chimney-sweeping/research">Research 3095</a>
      <a class="suburb-chip" href="/chimney-sweeping/heidelberg">Heidelberg 3084</a>
      <a class="suburb-chip" href="/chimney-sweeping/watsonia">Watsonia 3087</a>
      <a class="suburb-chip" href="/chimney-sweeping/bundoora">Bundoora 3083</a>
    </div>
  </section>

  <section class="sec">
    <p class="sec-label">More pages</p>
    <h2>Nearby Service Pages</h2>
    <nav class="page-links" aria-label="Nearby suburb pages">
      <a class="page-link" href="/chimney-sweeping/eltham">Chimney Sweeping — Eltham VIC 3095 <span>›</span></a>
      <a class="page-link" href="/chimney-sweeping/greensborough">Chimney Sweeping — Greensborough VIC 3088 <span>›</span></a>
      <a class="page-link" href="/chimney-sweeping/hurstbridge">Chimney Sweeping — Hurstbridge VIC 3099 <span>›</span></a>
      <a class="page-link" href="/">Chimney Sweeping Melbourne — All Suburbs <span>›</span></a>
    </nav>
  </section>

  <section class="bottom-cta">
    <h2>Diamond Creek Chimney Sweep — Get Started</h2>
    <p>Call Dave or use the form above. We'll confirm the details and get a time locked in.</p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="#quote">Request a Quote</a>
    </div>
  </section>
</MainLayout>
