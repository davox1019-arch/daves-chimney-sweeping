const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["Ivanhoe VIC 3079"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/ivanhoe", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Ivanhoe VIC 3079. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "Ivanhoe", "addressRegion": "VIC", "postalCode": "3079", "addressCountry": "AU"}};
