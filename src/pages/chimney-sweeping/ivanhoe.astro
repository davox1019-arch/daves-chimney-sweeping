      <a class="suburb-chip" href="/chimney-sweeping/greensborough">Greensborough 3088</a>
      <a class="suburb-chip" href="/chimney-sweeping/bundoora">Bundoora 3083</a>
      <a class="suburb-chip" href="/chimney-sweeping/eltham">Eltham 3095</a>
