const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Cheltenham VIC 3192", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Cheltenham VIC 3192", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
const faqs = [
  {q:`Do you service Cheltenham VIC 3192?`,a:`Yes — Cheltenham is part of our bayside Melbourne run. We cover Cheltenham and nearby suburbs including Hampton, Brighton, Moorabbin and Mentone.`},
  {q:`Our Cheltenham home has the original postwar fireplace and we don't think it has ever been professionally cleaned — is that a concern?`,a:`Yes. A fireplace that has been used regularly without professional cleaning can accumulate significant creosote in the flue, which becomes a fire risk. We will clean and inspect the full system and give you a clear picture of its condition.`},
  {q:`What does the $199 service include?`,a:`Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee — $199 per chimney.`},
  {q:`How often should a Cheltenham home have its chimney cleaned?`,a:`Annually for a regularly used fireplace. The bayside humidity in this area can contribute to faster flue deterioration — consistent annual inspection catches any developing issues early.`},
  {q:`Is there a call-out fee for Cheltenham?`,a:`No — $199 flat rate per chimney, complete price.`}
];
---

<MainLayout
