  description="Chimney sweeping Cheltenham VIC 3192 — $199 chimney inspection & full clean. Daves Chimney Sweeping: flue cleaning, wood heater service. Call 0476 302 729."
  clusterBase="Melbourne's Bayside Suburbs"
  clusterRegion="Melbourne's bayside suburbs"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Chimney Sweep Cheltenham 3192</h1>
      <p class="hero-sub">$199 chimney inspection &amp; full clean &mdash; Cheltenham &amp; surrounds. Owner-operated, no call-out fee, same-week bookings.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:0476302729">Call 0476&nbsp;302&nbsp;729</a>
        <a class="btn-secondary" href="#booking">Get a Quote</a>
