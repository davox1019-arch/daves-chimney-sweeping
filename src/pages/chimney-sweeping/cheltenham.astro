const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["Cheltenham VIC 3192"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/cheltenham", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Cheltenham VIC 3192. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "Cheltenham", "addressRegion": "VIC", "postalCode": "3192", "addressCountry": "AU"}};
