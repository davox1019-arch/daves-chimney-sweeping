const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Pakenham VIC 3810", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Pakenham VIC 3810", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
