---
import MainLayout from "../../layouts/MainLayout.astro";

const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["Brunswick VIC 3056"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/brunswick", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in Brunswick VIC 3056. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "Brunswick", "addressRegion": "VIC", "postalCode": "3056", "addressCountry": "AU"}};
const faqSchema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Do you service Brunswick VIC 3056?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 Brunswick is part of our inner northern Melbourne run. We cover Brunswick and surrounding suburbs including Northcote, Coburg, Fitzroy North and Thornbury."}}, {"@type": "Question", "name": "Our Brunswick terrace has two fireplaces sharing a stack \u2014 can both be cleaned?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Party-wall chimney stacks with two flues are common in Brunswick terraces and we handle them regularly. Both flues get individually swept and inspected in a single visit."}}, {"@type": "Question", "name": "What does the $199 service include?", "acceptedAnswer": {"@type": "Answer", "text": "Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee \u2014 $199 per chimney."}}, {"@type": "Question", "name": "We want to reopen a fireplace that has been sealed for years \u2014 what is involved?", "acceptedAnswer": {"@type": "Answer", "text": "We can open, inspect and clean a previously sealed fireplace. We will check the flue for blockages, debris and any deterioration before you light it for the first time."}}, {"@type": "Question", "name": "Is there a call-out fee for Brunswick?", "acceptedAnswer": {"@type": "Answer", "text": "No \u2014 $199 flat rate per chimney, complete price."}}]};
const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Brunswick VIC 3056", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Brunswick VIC 3056", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
const faqs = [
  {q:`Do you service Brunswick VIC 3056?`,a:`Yes — Brunswick is part of our inner northern Melbourne run. We cover Brunswick and surrounding suburbs including Northcote, Coburg, Fitzroy North and Thornbury.`},
  {q:`Our Brunswick terrace has two fireplaces sharing a stack — can both be cleaned?`,a:`Yes. Party-wall chimney stacks with two flues are common in Brunswick terraces and we handle them regularly. Both flues get individually swept and inspected in a single visit.`},
  {q:`What does the $199 service include?`,a:`Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee — $199 per chimney.`},
  {q:`We want to reopen a fireplace that has been sealed for years — what is involved?`,a:`We can open, inspect and clean a previously sealed fireplace. We will check the flue for blockages, debris and any deterioration before you light it for the first time.`},
  {q:`Is there a call-out fee for Brunswick?`,a:`No — $199 flat rate per chimney, complete price.`}
];
---

<MainLayout
  title="Chimney Sweep Brunswick VIC 3056 — $199 Clean & Inspect"
  description="Chimney sweeping Brunswick VIC 3056 — $199 chimney inspection & full clean. Daves Chimney Sweeping: flue cleaning, wood heater service. Call 0476 302 729."
  clusterBase="Melbourne's Inner Northern Suburbs"
  clusterRegion="Melbourne's inner northern suburbs"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Chimney Sweep Brunswick 3056</h1>
      <p class="hero-sub">$199 chimney inspection &amp; full clean &mdash; Brunswick &amp; surrounds. Owner-operated, no call-out fee, same-week bookings.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:0476302729">Call 0476&nbsp;302&nbsp;729</a>
        <a class="btn-secondary" href="#booking">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <span>&#10003; $199 flat rate</span>
    <span>&#10003; No call-out fee</span>
    <span>&#10003; Same-week bookings</span>
    <span>&#10003; Owner-operated</span>
    <span>&#10003; Brunswick &amp; surrounds</span>
  </section>

  <!-- PRICING -->
  <section class="pricing-section" id="pricing">
    <h2>Chimney Sweep Brunswick — Pricing</h2>
    <div class="price-card">
      <div class="price-amount">$199</div>
      <div class="price-label">Full chimney inspection &amp; clean</div>
      <ul class="price-includes">
        <li>Full sweep from firebox to pot</li>
        <li>Flue clean &amp; soot removal</li>
        <li>Creosote &amp; blockage check</li>
        <li>Bird nest removal if present</li>
        <li>Verbal condition report</li>
        <li>No call-out fee</li>
      </ul>
      <a class="btn-primary" href="tel:0476302729">Book Now — 0476 302 729</a>
    </div>
  </section>

  <!-- LOCAL KNOWLEDGE -->
  <section class="local-section" id="local">
    <h2>Chimney Sweeping in Brunswick</h2>
    <div class="local-box"><p>Brunswick developed from the 1870s through the interwar period as one of Melbourne's most densely built inner suburbs, with terrace housing, double-fronted brick cottages and Edwardian weatherboards lining virtually every residential street. The suburb is characterised by a high concentration of original period homes — many still owner-occupied by long-term residents or purchased by renovators who have carefully restored the original features including the fireplaces. Brunswick's housing stock is particularly notable for double-fireplace configurations: many of the terrace and semi-detached homes have a fireplace in both the front sitting room and the rear bedroom, with a shared stack running up through the party wall. Both fireplaces and both flues need annual cleaning for safely used systems. The suburb sits in the Moonee Ponds Creek valley's eastern catchment, and the low-lying northern end of Brunswick can accumulate cold air through winter nights, making wood heating a genuine necessity rather than a luxury in many homes. We service Brunswick regularly and are familiar with the compact terrace chimney configurations, shared party-wall stacks and Victorian-era lime mortar systems common throughout the suburb.</p></div>
  </section>

  <!-- SIGNS -->
  <section class="signs-section" id="signs">
    <h2>Signs Your Brunswick Chimney Needs Cleaning</h2>
    <ul class="signs-list">
      <li>Smoke pushing back into the room, especially in the rear bedroom fireplace</li>
      <li>A musty or smoky smell in the house on cold mornings when the fire isn't lit</li>
      <li>Soot marks or dark staining around the firebox opening</li>
      <li>A fireplace that has been unused for several years and is being reactivated</li>
      <li>Slow draw in one fireplace when the other is lit</li>
    </ul>
  </section>

  <!-- SERVICES -->
  <section class="services-section" id="services">
    <h2>Chimney Services in Brunswick</h2>
    <div class="services-grid">
      <div class="service-card"><h3>Chimney Sweep</h3><p>Full brush sweep from firebox to pot. Soot, creosote and debris removed. Verbal condition report included.</p></div>
      <div class="service-card"><h3>Flue Cleaning</h3><p>Thorough flue clean using professional brushes and equipment. Removes accumulated creosote and restores full draw.</p></div>
      <div class="service-card"><h3>Wood Heater Service</h3><p>Slow combustion heater flue clean and inspection. Baffle check, door seal inspection, full flue swept top to bottom.</p></div>
      <div class="service-card"><h3>Chimney Inspection</h3><p>Visual inspection of firebox, flue, damper, crown and pot. Written report available on request. Included in the $199 service.</p></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews-section" id="reviews">
    <h2>What Brunswick Customers Say</h2>
    <div class="reviews-grid">
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;Terrace with two original fireplaces sharing a stack. David explained exactly how the party-wall system works and swept both flues without making a mess. Brilliant — will be booking annually.&rdquo;</p><p class="review-author">Claudia V., Brunswick</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;We renovated our Brunswick cottage and got the front fireplace working again after twenty years. David swept the flue, checked the liner and cleared out a bird nest near the pot. Couldn't be happier.&rdquo;</p><p class="review-author">Tom H., Brunswick</p></div>
      <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">&ldquo;David cleaned both chimneys and pointed out a gap in the flashing we hadn't noticed. Very thorough and great value at $199 each. Would strongly recommend.&rdquo;</p><p class="review-author">Sarah K., Brunswick</p></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <h2>About Dave&rsquo;s Chimney Sweeping</h2>
    <p>Dave&rsquo;s Chimney Sweeping is a local, owner-operated business covering Melbourne's inner northern suburbs including Brunswick. Dave personally handles every job &mdash; no subcontractors, no call centres. Flat $199 rate per chimney, no hidden fees.</p>
    <a class="btn-secondary" href="tel:0476302729">Call Dave — 0476 302 729</a>
  </section>

  <!-- FAQs -->
  <section class="faq-section" id="faq">
    <h2>Chimney Sweep Brunswick — FAQs</h2>
    {faqs.map(f => (
    <details>
      <summary>{f.q}</summary>
      <p>{f.a}</p>
    </details>
    ))}
  </section>

  <!-- BOOKING FORM -->
  <section class="booking-section" id="booking">
    <h2>Book a Chimney Sweep in Brunswick</h2>
    <form action="https://formspree.io/f/xdkobvpv" method="POST" class="booking-form">
      <input type="hidden" name="suburb" value="Brunswick 3056" />
      <label>Name <input type="text" name="name" required /></label>
      <label>Phone <input type="tel" name="phone" required /></label>
      <label>Email <input type="email" name="email" /></label>
      <label>Message <textarea name="message" rows="3">Chimney sweep enquiry — Brunswick 3056</textarea></label>
      <button type="submit" class="btn-primary">Send Enquiry</button>
    </form>
  </section>

  <!-- NEARBY SUBURBS -->
  <section class="nearby-section" id="nearby">
    <h2>Nearby Areas We Service</h2>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/northcote">Northcote 3070</a>
      <a class="suburb-chip" href="/chimney-sweeping/coburg">Coburg 3058</a>
      <a class="suburb-chip" href="/chimney-sweeping/fitzroy-north">Fitzroy North 3068</a>
      <a class="suburb-chip" href="/chimney-sweeping/preston">Preston 3072</a>
      <a class="suburb-chip" href="/chimney-sweeping/thornbury">Thornbury 3071</a>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo; <a href="/#service-areas">Service Areas</a> &rsaquo; Brunswick
  </nav>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <h2>Ready to book your Brunswick chimney sweep?</h2>
    <p>$199 flat rate &mdash; no call-out fee &mdash; same-week bookings available.</p>
    <a class="btn-primary" href="tel:0476302729">Call 0476 302 729</a>
  </section>

  <!-- STICKY MOBILE CTA -->
  <a href="tel:0476302729" id="sticky-cta" aria-label="Call or text Dave">
    <span id="sticky-icon">&#128222;</span>
    <span id="sticky-text">Call/Text Dave</span>
  </a>
  <style>
    #sticky-cta{position:fixed;bottom:1.25rem;right:1.25rem;z-index:999;display:flex;align-items:center;gap:.5rem;background:#e07b00;color:#fff;font-weight:700;font-size:1rem;padding:.75rem 1.25rem;border-radius:999px;box-shadow:0 4px 16px rgba(0,0,0,.25);text-decoration:none;transition:opacity .3s;opacity:0;pointer-events:none;}
    #sticky-cta.visible{opacity:1;pointer-events:auto}
    @media(min-width:768px){#sticky-cta{display:none}}
  </style>
  <script is:inline>
    (function(){
      var btn = document.getElementById('sticky-cta');
      var hero = document.querySelector('.hero');
      function check(){
        var threshold = hero ? hero.offsetHeight : 300;
        if(window.scrollY > threshold){ btn.classList.add('visible'); }
        else { btn.classList.remove('visible'); }
      }
      window.addEventListener('scroll', check, {passive:true});
      check();
    })();
  </script>

</MainLayout>
