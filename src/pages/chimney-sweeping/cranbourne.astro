const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Cranbourne VIC 3977", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Cranbourne VIC 3977", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
