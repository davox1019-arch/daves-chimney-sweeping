---
import MainLayout from "../../layouts/MainLayout.astro";
import SuburbSeo from "../../components/SuburbSeo.astro";

const pageTitle = "Chimney Sweep Diggers Rest VIC 3427 - $199 Clean & Inspect";
const pageDescription = "Chimney sweeping Diggers Rest VIC 3427 - $199 chimney inspection and full clean. Flue cleaning, wood heater service, owner-operated. Call 0476 302 729.";
const suburb = "Diggers Rest";
const postcode = "3427";
const faqs = [
  {
    "q": "Where is Diggers Rest in relation to Sunbury?",
    "a": "Diggers Rest VIC 3427 is a small suburb just south-east of Sunbury along the Calder Freeway corridor. We service it as part of the same Sunbury area run."
  },
  {
    "q": "My heater is slow combustion — do you clean those?",
    "a": "Yes. Slow combustion heaters are one of the most common types we work on. We clean the heater body and the flue in the same visit."
  },
  {
    "q": "How do I get a quote?",
    "a": "Call 0476 302 729 or use the contact form. We'll ask a few basic questions about your setup and give you a straight price."
  },
  {
    "q": "Is it worth cleaning if I only use the fireplace occasionally?",
    "a": "Yes — even occasional use produces some buildup, and chimneys that sit unused for months can attract birds nesting in the flue. An occasional check and clean is worthwhile."
  }
];
const nearbySuburbs = [
  {
    "slug": "sunbury",
    "label": "Sunbury 3429"
  },
  {
    "slug": "gisborne",
    "label": "Gisborne 3437"
  },
  {
    "slug": "riddells-creek",
    "label": "Riddells Creek 3431"
  }
];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  clusterBase="Sunbury"
  clusterRegion="Sunbury, Diggers Rest and nearby suburbs"
  homeHref="/"
  servicePageHref="/chimney-sweeping/sunbury"
  servicePageLabel="Sunbury Chimney Sweeping"
  suppressAbout={true}
>
  <SuburbSeo
    slug="diggers-rest"
    suburb={suburb}
    postcode={postcode}
    title={pageTitle}
    description={pageDescription}
    faqs={faqs}
  />

  <style>
    :root { --brand-dark: #1a1a18; --brand-mid: #2c2c29; --brand-accent: #c8500a; --brand-warm: #f5f0e8; --brand-white: #ffffff; --text-main: #1a1a18; --text-muted: #5a5a54; --border: #e2ddd4; --radius: 10px; }
    .hero { background: linear-gradient(160deg, #18120a 0%, #2c1a0c 55%, #1a1a18 100%); color: var(--brand-white); padding: 3.8rem 1.25rem 3.4rem; text-align: center; }
