    .review-card { background: var(--brand-warm); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
    .review-stars { color: #f59e0b; font-size: 1.1rem; margin-bottom: 0.5rem; letter-spacing: 0.05em; }
    .review-text { font-size: 0.97rem; line-height: 1.7; color: var(--text-muted); margin: 0 0 0.6rem; font-style: italic; }
    .review-author { font-size: 0.84rem; font-weight: 700; color: var(--text-main); }

    .about-fp { background: url('/images/fireplace.jpg') center/cover no-repeat; padding: 2.5rem 1rem; }
