  "priceRange": "$199–$299",
  "areaServed": [
    "Woodend VIC 3442",
    "Kyneton VIC 3444",
    "Romsey VIC 3434",
    "Gisborne VIC 3437",
    "Riddells Creek VIC 3431",
    "Lancefield VIC 3435",
    "Mount Macedon VIC 3441",
    "Macedon Ranges VIC"
  ],
  "url": "https://daveschimneysweeping.com.au/chimney-sweeping/macedon-ranges",
  "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning across the Macedon Ranges — Woodend, Kyneton, Romsey, Gisborne, Riddells Creek, Lancefield and surrounds. Flue and wood heater service $199, masonry brick chimney $299."
