const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping Point Cook VIC 3030", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "Point Cook VIC 3030", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
