---
import MainLayout from "../../layouts/MainLayout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61476302729",
  areaServed: [
    "Riddells Creek VIC 3431",
    "Gisborne VIC 3437",
    "Sunbury VIC 3429",
    "New Gisborne VIC 3438",
    "Macedon VIC 3440",
    "Diggers Rest VIC 3427"
  ],
  url: "https://daveschimneysweeping.com.au/chimney-sweeping/riddells-creek",
  description:
    "Daves Chimney Sweeping provides chimney sweeping, flue cleaning, wood heater cleaning and fireplace servicing in Riddells Creek VIC 3431 and nearby suburbs.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Riddells Creek",
    addressRegion: "VIC",
    postalCode: "3431",
    addressCountry: "AU"
  }
};

const localBusinessSchemaJson = JSON.stringify(localBusinessSchema);

const faqs = [
  {
    q: "Do you service all of Riddells Creek?",
    a: "Yes — we service Riddells Creek VIC 3431 and nearby areas. If you're just outside the suburb, give us a call and we'll confirm coverage."
  },
  {
    q: "Do you clean wood heater flues as well as fireplaces?",
    a: "Yes. We handle wood heater flues, chimneys and fireplace cleaning depending on the setup in your home."
  },
  {
    q: "How do I know when my chimney needs cleaning?",
    a: "Common signs include soot buildup, smoke drifting back inside, poor draft, stronger odours than usual or a fireplace that hasn't been cleaned in a long time."
  },
  {
    q: "Can you remove bird nests or other blockages?",
    a: "Yes. Bird nests and debris blockages are a common issue, and we can clear them as part of the service."
  },
  {
    q: "How long does a chimney sweep usually take?",
    a: "Most jobs take around 45 minutes to 90 minutes, depending on the setup and how much buildup is inside the system."
  }
];
---

<MainLayout
  title="Chimney Sweeping Riddells Creek VIC 3431"
  description="Local chimney sweeping in Riddells Creek VIC 3431. Daves Chimney Sweeping handles flue cleaning, wood heater servicing and fireplace cleaning. Fast quotes, no fuss."
  clusterBase="Sunbury"
  clusterRegion="Sunbury, Diggers Rest and nearby suburbs"
  homeHref="/chimney-sweeping/sunbury"
  servicePageHref="/chimney-sweeping/sunbury"
  servicePageLabel="Sunbury Chimney Sweeping"
>
  <script type="application/ld+json" is:inline set:html={localBusinessSchemaJson}></script>

  <style>
    :root {
      --brand-dark: #1f1e1b;
      --brand-mid: #2a2824;
      --brand-accent: #b65d1e;
      --brand-white: #ffffff;
      --brand-warm: #f5f1ea;
      --text-main: #1a1a18;
      --text-muted: #5e5a53;
      --border: #e2ddd4;
      --radius: 10px;
    }

    .hero {
      background: linear-gradient(180deg, var(--brand-mid) 0%, var(--brand-dark) 100%);
      padding: 2.75rem 1.25rem 2.4rem;
      text-align: center;
      border-bottom: 1px solid #2f2c27;
    }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: 0.85rem;
    }

    .hero h1 {
      font-size: clamp(1.65rem, 5vw, 2.2rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
      color: var(--brand-white);
    }

    .hero-lead {
      font-size: 1rem;
      line-height: 1.65;
      color: #c8c5be;
      margin: 0 auto 0.75rem;
      max-width: 500px;
    }

    .hero-sub {
      font-size: 0.93rem;
      line-height: 1.6;
      color: #908d86;
      max-width: 500px;
      margin: 0 auto 2rem;
    }

    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }

    .btn {
      display: inline-block;
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      width: 100%;
      max-width: 320px;
      transition: opacity 0.15s;
    }

    .btn:hover {
      opacity: 0.88;
    }

    .btn-call {
      background: var(--brand-accent);
      color: #fff;
      font-size: 1.1rem;
      letter-spacing: 0.01em;
    }

    .btn-quote {
      background: transparent;
      border: 2px solid #5a5a54;
      color: #c8c5be;
    }

    .trust-bar {
      background: var(--brand-mid);
      padding: 0.95rem 1.25rem;
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: #908d86;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .trust-item svg {
      flex-shrink: 0;
      color: var(--brand-accent);
    }

    .section {
      padding: 2.2rem 1.25rem;
      max-width: 680px;
      margin: 0 auto;
    }

    .section + .section {
      border-top: 1px solid var(--border);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: 0.55rem;
    }

    .section h2 {
      font-size: clamp(1.25rem, 4vw, 1.6rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text-main);
      margin: 0 0 1rem;
      line-height: 1.25;
    }

    .section p {
      font-size: 0.96rem;
      line-height: 1.72;
      color: var(--text-muted);
      margin: 0 0 0.9rem;
    }

    .section p:last-child {
      margin-bottom: 0;
    }

    .service-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: 1.25rem;
    }

    @media (max-width: 380px) {
      .service-grid {
        grid-template-columns: 1fr;
      }
    }

    .service-card {
      background: var(--brand-warm);
      border-radius: var(--radius);
      padding: 1rem 1rem 0.9rem;
      border: 1px solid var(--border);
    }

    .service-card-icon {
      font-size: 1.5rem;
      margin-bottom: 0.4rem;
      display: block;
    }

    .service-card-title {
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--text-main);
      line-height: 1.3;
    }

    .check-list {
      list-style: none;
      padding: 0;
      margin: 1.1rem 0 0;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    .check-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--text-muted);
    }

    .check-list li::before {
      content: "→";
      color: var(--brand-accent);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 0.05em;
    }

    .about-card {
      background: var(--brand-warm);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.5rem 1.25rem;
      margin-top: 1rem;
    }

    .about-card p {
      font-size: 0.96rem;
      line-height: 1.7;
      color: var(--text-muted);
      margin: 0 0 0.8rem;
    }

    .about-detail {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.88rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    .about-detail strong {
      color: var(--text-main);
    }

    .about-detail a {
      color: var(--brand-accent);
      font-weight: 700;
      text-decoration: none;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 1.25rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    details.faq-item {
      border-bottom: 1px solid var(--border);
    }

    details.faq-item:last-child {
      border-bottom: none;
    }

    details.faq-item summary {
      padding: 1rem 1.1rem;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-main);
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      background: var(--brand-white);
      transition: background 0.15s;
    }

    details.faq-item summary::-webkit-details-marker {
      display: none;
    }

    details.faq-item summary:hover {
      background: var(--brand-warm);
    }

    details.faq-item summary::after {
      content: "+";
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--brand-accent);
      flex-shrink: 0;
      margin-left: 1rem;
    }

    details.faq-item[open] summary::after {
      content: "−";
    }

    .faq-answer {
      padding: 0 1.1rem 1rem;
      font-size: 0.93rem;
      line-height: 1.7;
      color: var(--text-muted);
      background: var(--brand-white);
    }

    .suburb-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 1.1rem;
    }

    .suburb-chip {
      display: inline-block;
      background: var(--brand-warm);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.45rem 0.85rem;
      font-size: 0.84rem;
      font-weight: 600;
      color: var(--text-main);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .suburb-chip:hover {
      background: var(--brand-accent);
      border-color: var(--brand-accent);
      color: #fff;
    }

    .page-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1.1rem;
    }

    .page-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1rem;
      background: var(--brand-warm);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      text-decoration: none;
      font-size: 0.93rem;
      font-weight: 600;
      color: var(--text-main);
      transition: background 0.15s, border-color 0.15s;
    }

    .page-link:hover {
      background: var(--brand-accent);
      border-color: var(--brand-accent);
      color: #fff;
    }

    .page-link span {
      opacity: 0.5;
      font-size: 1.1rem;
    }

    .bottom-cta {
      background: var(--brand-dark);
      color: var(--brand-white);
      padding: 2.5rem 1.25rem;
      text-align: center;
    }

    .bottom-cta h2 {
      font-size: clamp(1.3rem, 4.5vw, 1.7rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--brand-white);
      margin: 0 0 0.6rem;
    }

    .bottom-cta p {
      font-size: 0.95rem;
      color: #908d86;
      margin: 0 0 1.75rem;
      line-height: 1.6;
    }
  </style>

  <section class="hero">
    <span class="hero-eyebrow">Riddells Creek VIC 3431</span>
    <h1>Chimney Sweeping<br>Riddells Creek VIC 3431</h1>
    <p class="hero-lead">
      Daves Chimney Sweeping handles chimney and flue cleaning, wood heater servicing and fireplace maintenance for homes in Riddells Creek and nearby parts of the Macedon Ranges corridor.
    </p>
    <p class="hero-sub">
      If your fireplace has been heavily used through winter, the flue smells stronger than usual, or the draft just doesn't feel right anymore, we can sort it out properly.
    </p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

  <div class="trust-bar">
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Riddells Creek locals
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
