---
import MainLayout from "../../layouts/MainLayout.astro";
import SuburbSeo from "../../components/SuburbSeo.astro";

const pageTitle = "Chimney Sweep Riddells Creek VIC 3431 - $199 Clean & Inspect";
const pageDescription = "Chimney sweeping Riddells Creek VIC 3431 - $199 chimney inspection and full clean. Flue cleaning, wood heater service, owner-operated. Call 0476 302 729.";
const suburb = "Riddells Creek";
const postcode = "3431";
const faqs = [
  {
    "q": "Do you service all of Riddells Creek?",
    "a": "Yes — we service Riddells Creek VIC 3431 and nearby areas. If you're just outside the suburb, give us a call and we'll confirm coverage."
  },
  {
    "q": "Do you clean wood heater flues as well as fireplaces?",
    "a": "Yes. We handle wood heater flues, chimneys and fireplace cleaning depending on the setup in your home."
  },
  {
    "q": "How do I know when my chimney needs cleaning?",
    "a": "Common signs include soot buildup, smoke drifting back inside, poor draft, stronger odours than usual or a fireplace that hasn't been cleaned in a long time."
  },
  {
    "q": "Can you remove bird nests or other blockages?",
    "a": "Yes. Bird nests and debris blockages are a common issue, and we can clear them as part of the service."
  },
  {
    "q": "How long does a chimney sweep usually take?",
    "a": "Most jobs take around 45 minutes to 90 minutes, depending on the setup and how much buildup is inside the system."
  }
];
const nearbySuburbs = [
  {
    "slug": "gisborne",
    "label": "Gisborne 3437"
  },
  {
    "slug": "sunbury",
    "label": "Sunbury 3429"
  },
  {
    "slug": "diggers-rest",
    "label": "Diggers Rest 3427"
  }
];
