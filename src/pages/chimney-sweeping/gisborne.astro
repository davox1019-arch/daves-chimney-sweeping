---
import MainLayout from "../../layouts/MainLayout.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Daves Chimney Sweeping",
  telephone: "+61476302729",
  areaServed: [
    "Gisborne VIC 3437",
    "New Gisborne VIC 3438",
    "Riddells Creek VIC 3431",
    "Sunbury VIC 3429",
    "Macedon VIC 3440",
    "Diggers Rest VIC 3427"
  ],
  url: "https://daveschimneysweeping.com.au/chimney-sweeping/gisborne",
  description:
    "Daves Chimney Sweeping provides chimney sweeping, flue cleaning, wood heater cleaning and fireplace servicing in Gisborne VIC 3437 and nearby suburbs.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Gisborne",
    addressRegion: "VIC",
    postalCode: "3437",
    addressCountry: "AU"
  }
};

const localBusinessSchemaJson = JSON.stringify(localBusinessSchema);

const faqs = [
  {
    q: "Do you service homes across Gisborne?",
    a: "Yes. We service Gisborne VIC 3437 and nearby surrounding areas. If you're close by and not completely sure, just call and we'll confirm it for you."
  },
  {
    q: "Can you clean both chimneys and wood heater flues?",
    a: "Yes. We clean chimneys, fireplace flues and wood heater systems depending on the setup in your home."
  },
  {
    q: "What usually tells me a chimney clean is overdue?",
    a: "Smoke drifting back inside, black soot buildup, a weaker draft, stronger smells than usual, or a fireplace that has gone a long time without a clean are all common signs."
  },
  {
    q: "Do you deal with bird nests and chimney blockages?",
    a: "Yes. Nesting material and debris blockages are common and we can clear them as part of the service."
  },
  {
    q: "How long does a typical job take?",
    a: "Most chimney sweeping jobs take around 45 to 90 minutes depending on access, the type of fireplace or heater, and how much buildup is inside."
  }
];
---

<MainLayout
  title="Chimney Sweeping Gisborne VIC 3437"
  description="Need chimney sweeping in Gisborne VIC 3437? Daves Chimney Sweeping provides local chimney cleaning, flue cleaning and wood heater servicing with fast quotes."
  clusterBase="Sunbury"
  clusterRegion="Sunbury, Diggers Rest and nearby suburbs"
  homeHref="/chimney-sweeping/sunbury"
  servicePageHref="/chimney-sweeping/sunbury"
  servicePageLabel="Sunbury Chimney Sweeping"
>
  <script type="application/ld+json" is:inline set:html={localBusinessSchemaJson}></script>

  <style>
    :root {
      --brand-dark: #1f1e1b;
      --brand-mid: #2a2824;
      --brand-accent: #b65d1e;
      --brand-white: #ffffff;
      --brand-warm: #f5f1ea;
      --brand-soft: #fbf8f3;
      --text-main: #1a1a18;
      --text-muted: #5e5a53;
      --border: #e2ddd4;
      --radius: 10px;
    }

    .hero {
      background: linear-gradient(180deg, var(--brand-mid) 0%, var(--brand-dark) 100%);
      padding: 2.75rem 1.25rem 2.4rem;
      text-align: center;
      border-bottom: 1px solid #2f2c27;
    }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: 0.85rem;
    }

    .hero h1 {
      font-size: clamp(1.65rem, 5vw, 2.2rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
      color: var(--brand-white);
    }

    .hero-lead {
      font-size: 1rem;
      line-height: 1.65;
      color: #c8c5be;
      margin: 0 auto 0.75rem;
      max-width: 520px;
    }

    .hero-sub {
      font-size: 0.93rem;
      line-height: 1.6;
      color: #908d86;
      max-width: 520px;
      margin: 0 auto 2rem;
    }

    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }

    .btn {
      display: inline-block;
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      width: 100%;
      max-width: 320px;
      transition: opacity 0.15s;
    }

    .btn:hover {
      opacity: 0.88;
    }

    .btn-call {
      background: var(--brand-accent);
      color: #fff;
      font-size: 1.1rem;
      letter-spacing: 0.01em;
    }

    .btn-quote {
      background: transparent;
      border: 2px solid #5a5a54;
      color: #c8c5be;
    }

    .trust-bar {
      background: var(--brand-mid);
      padding: 0.95rem 1.25rem;
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: #908d86;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .trust-item svg {
      flex-shrink: 0;
      color: var(--brand-accent);
    }

    .section {
      padding: 2.2rem 1.25rem;
      max-width: 680px;
      margin: 0 auto;
    }

    .section + .section {
      border-top: 1px solid var(--border);
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: 0.55rem;
    }

    .section h2 {
      font-size: clamp(1.25rem, 4vw, 1.6rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text-main);
      margin: 0 0 1rem;
      line-height: 1.25;
    }

    .section p {
      font-size: 0.96rem;
      line-height: 1.72;
      color: var(--text-muted);
      margin: 0 0 0.9rem;
    }

    .section p:last-child {
      margin-bottom: 0;
    }

    .problem-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.25rem;
    }

    .problem-card {
      background: var(--brand-soft);
      border-radius: var(--radius);
      padding: 1rem 1rem 0.95rem;
      border: 1px solid var(--border);
    }

    .problem-card-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text-main);
      margin-bottom: 0.35rem;
    }

    .problem-card p {
      font-size: 0.92rem;
      margin: 0;
    }

    .service-list {
      list-style: none;
      padding: 0;
      margin: 1.1rem 0 0;
      display: grid;
      gap: 0.65rem;
    }

    .service-list li {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 0.95rem;
      line-height: 1.55;
      color: var(--text-muted);
    }

    .service-list li::before {
      content: "→";
      color: var(--brand-accent);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 0.05em;
    }

    .area-box {
      background: var(--brand-warm);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.2rem 1.1rem;
      margin-top: 1rem;
    }

    .area-box p {
      margin: 0 0 0.85rem;
    }

    .suburb-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .suburb-chip {
      display: inline-block;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.45rem 0.85rem;
      font-size: 0.84rem;
      font-weight: 600;
      color: var(--text-main);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .suburb-chip:hover {
      background: var(--brand-accent);
      border-color: var(--brand-accent);
      color: #fff;
    }

    .about-card {
      background: var(--brand-warm);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.5rem 1.25rem;
      margin-top: 1rem;
    }

    .about-card p {
      font-size: 0.96rem;
      line-height: 1.7;
      color: var(--text-muted);
      margin: 0 0 0.8rem;
    }

    .about-detail {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.88rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    .about-detail strong {
      color: var(--text-main);
    }

    .about-detail a {
      color: var(--brand-accent);
      font-weight: 700;
      text-decoration: none;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 1.25rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    details.faq-item {
      border-bottom: 1px solid var(--border);
    }

    details.faq-item:last-child {
      border-bottom: none;
    }

    details.faq-item summary {
      padding: 1rem 1.1rem;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-main);
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      background: var(--brand-white);
      transition: background 0.15s;
    }

    details.faq-item summary::-webkit-details-marker {
      display: none;
    }

    details.faq-item summary:hover {
      background: var(--brand-warm);
    }

    details.faq-item summary::after {
      content: "+";
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--brand-accent);
      flex-shrink: 0;
      margin-left: 1rem;
    }

    details.faq-item[open] summary::after {
      content: "−";
    }

    .faq-answer {
      padding: 0 1.1rem 1rem;
      font-size: 0.93rem;
      line-height: 1.7;
      color: var(--text-muted);
      background: var(--brand-white);
    }

    .page-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1.1rem;
    }

    .page-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1rem;
      background: var(--brand-warm);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      text-decoration: none;
      font-size: 0.93rem;
      font-weight: 600;
      color: var(--text-main);
      transition: background 0.15s, border-color 0.15s;
    }

    .page-link:hover {
      background: var(--brand-accent);
      border-color: var(--brand-accent);
      color: #fff;
    }

    .page-link span {
      opacity: 0.5;
      font-size: 1.1rem;
    }

    .bottom-cta {
      background: var(--brand-dark);
      color: var(--brand-white);
      padding: 2.5rem 1.25rem;
      text-align: center;
    }

    .bottom-cta h2 {
      font-size: clamp(1.3rem, 4.5vw, 1.7rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--brand-white);
      margin: 0 0 0.6rem;
    }

    .bottom-cta p {
      font-size: 0.95rem;
      color: #908d86;
      margin: 0 0 1.75rem;
      line-height: 1.6;
    }
  </style>

  <section class="hero">
    <span class="hero-eyebrow">Gisborne VIC 3437</span>
    <h1>Chimney Sweeping<br>Gisborne VIC 3437</h1>
    <p class="hero-lead">
      Daves Chimney Sweeping provides local chimney sweeping, flue cleaning and wood heater servicing for homes in Gisborne and surrounding parts of the wider Macedon Ranges area.
    </p>
    <p class="hero-sub">
      If your fireplace has been working hard through winter, the flue has a stronger smell than normal, or the draw just feels weaker than it should, we can get it cleaned properly.
    </p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

  <div class="trust-bar">
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Gisborne service
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Owner-operated
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Fast quotes
    </span>
  </div>

  <section class="section">
    <p class="section-label">Common issues</p>
    <h2>What Usually Brings People in Gisborne to Book a Clean</h2>
    <p>
      Some people book before winter starts. Others wait until the fireplace begins showing signs that cleaning is overdue. Either way, the earlier buildup is dealt with, the easier the whole system is to use.
    </p>

    <div class="problem-grid">
      <div class="problem-card">
        <div class="problem-card-title">Smoke drifting back into the room</div>
        <p>This often points to draft issues, buildup inside the flue, or a blockage that needs clearing.</p>
      </div>
      <div class="problem-card">
        <div class="problem-card-title">Visible soot and ash residue</div>
        <p>If black buildup is obvious around the fireplace or heater, the chimney system is often due for a proper clean too.</p>
      </div>
      <div class="problem-card">
        <div class="problem-card-title">Weaker airflow than usual</div>
        <p>A sluggish draft can make lighting and maintaining a fire more frustrating than it should be.</p>
      </div>
      <div class="problem-card">
        <div class="problem-card-title">Long time since the last service</div>
        <p>If it has been a year or more, many homeowners simply book a clean to stay ahead of problems.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">What we clean</p>
    <h2>Chimneys, Flues, Fireplaces and Wood Heaters</h2>
    <p>
      We clean the main parts of the system, not just the visible section. That includes chimney sweeping, flue cleaning and servicing for wood heater setups depending on what your home has installed.
    </p>

    <ul class="service-list">
      <li>Chimney sweeping for fireplaces and heater systems</li>
      <li>Flue cleaning for wood heaters and related setups</li>
      <li>Fireplace cleaning and soot removal</li>
      <li>Clearing bird nests and common debris blockages</li>
      <li>Cleaning jobs before winter or after heavy seasonal use</li>
      <li>Straightforward local service with direct contact</li>
    </ul>
  </section>

  <section class="section">
    <p class="section-label">Nearby suburbs</p>
    <h2>Areas Around Gisborne We Also Service</h2>
    <div class="area-box">
      <p>
        We also service nearby areas around Gisborne, including New Gisborne, Riddells Creek, Macedon, Sunbury and Diggers Rest.
      </p>
      <div class="suburb-chips">
        <a class="suburb-chip" href="/chimney-sweeping/riddells-creek">Riddells Creek 3431</a>
        <a class="suburb-chip" href="/chimney-sweeping/sunbury">Sunbury 3429</a>
        <a class="suburb-chip" href="/chimney-sweeping/diggers-rest">Diggers Rest 3427</a>
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">About us</p>
    <h2>Direct Local Service Without the Usual Runaround</h2>
    <div class="about-card">
      <p>
        Daves Chimney Sweeping is a local owner-operated service. When you call, you are speaking directly with the business rather than a call centre or booking platform.
      </p>
      <p>
        We keep it simple: turn up, clean the system properly, explain what we found and make it easy to get the job sorted.
      </p>
      <div class="about-detail">
        📞 <strong>Phone:</strong>&nbsp;<a href="tel:0476302729">0476 302 729</a>
      </div>
      <div class="about-detail">
        📍 <strong>Service area:</strong>&nbsp;Gisborne VIC 3437 and nearby suburbs
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">FAQs</p>
    <h2>Questions We Get About Chimney Sweeping in Gisborne</h2>
    <div class="faq-list">
      {faqs.map(({ q, a }) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <div class="faq-answer">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="section-label">Nearby pages</p>
    <h2>Related Service Pages</h2>
    <nav class="page-links" aria-label="Nearby suburb pages">
      <a class="page-link" href="/chimney-sweeping/riddells-creek">
        Chimney Sweeping — Riddells Creek VIC 3431
        <span>›</span>
      </a>
      <a class="page-link" href="/chimney-sweeping/sunbury">
        Chimney Sweeping — Sunbury VIC 3429
        <span>›</span>
      </a>
      <a class="page-link" href="/chimney-sweeping/diggers-rest">
        Chimney Sweeping — Diggers Rest VIC 3427
        <span>›</span>
      </a>
      <a class="page-link" href="/contact">
        Get a Quote
        <span>›</span>
      </a>
    </nav>
  </section>

  <section class="bottom-cta">
    <h2>Need Chimney Sweeping in Gisborne?</h2>
    <p>
      If your fireplace or wood heater is due for a proper clean, get in touch for a fast local quote.
    </p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>
</MainLayout>