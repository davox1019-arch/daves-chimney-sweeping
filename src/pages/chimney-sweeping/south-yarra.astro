const schema = {"@context": "https://schema.org", "@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729", "priceRange": "$199", "areaServed": ["South Yarra VIC 3141"], "url": "https://daveschimneysweeping.com.au/chimney-sweeping/south-yarra", "description": "Daves Chimney Sweeping provides chimney sweeping, flue cleaning and wood heater cleaning in South Yarra VIC 3141. $199 chimney inspection and clean.", "address": {"@type": "PostalAddress", "addressLocality": "South Yarra", "addressRegion": "VIC", "postalCode": "3141", "addressCountry": "AU"}};
const faqSchema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Do you service South Yarra VIC 3141?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 South Yarra is part of our inner eastern Melbourne run. We cover South Yarra and nearby suburbs including Richmond, Hawthorn, Prahran and Malvern."}}, {"@type": "Question", "name": "We are reopening a fireplace after a renovation \u2014 what needs to happen before we use it?", "acceptedAnswer": {"@type": "Answer", "text": "A full inspection and clean. We will check the flue for blockages, debris, bird nests and any damage from the building work before you light the first fire. It is the correct step before using a fireplace that has been dormant or worked on."}}, {"@type": "Question", "name": "What does the $199 service include?", "acceptedAnswer": {"@type": "Answer", "text": "Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee \u2014 $199 per chimney."}}, {"@type": "Question", "name": "Our South Yarra home has two fireplaces \u2014 can both be cleaned in one visit?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Multi-fireplace visits are straightforward \u2014 just let us know the number of chimneys when you book so we can allow the right amount of time."}}, {"@type": "Question", "name": "Is there a call-out fee for South Yarra?", "acceptedAnswer": {"@type": "Answer", "text": "No \u2014 $199 flat rate per chimney, complete price."}}]};
const serviceSchema = {"@context": "https://schema.org", "@type": "Service", "name": "Chimney Sweeping South Yarra VIC 3141", "provider": {"@type": "LocalBusiness", "name": "Daves Chimney Sweeping", "telephone": "+61476302729"}, "areaServed": "South Yarra VIC 3141", "offers": {"@type": "Offer", "price": "199", "priceCurrency": "AUD", "description": "Chimney inspection and full clean"}, "serviceType": "Chimney Sweeping"};
const faqs = [
  {q:`Do you service South Yarra VIC 3141?`,a:`Yes — South Yarra is part of our inner eastern Melbourne run. We cover South Yarra and nearby suburbs including Richmond, Hawthorn, Prahran and Malvern.`},
  {q:`We are reopening a fireplace after a renovation — what needs to happen before we use it?`,a:`A full inspection and clean. We will check the flue for blockages, debris, bird nests and any damage from the building work before you light the first fire. It is the correct step before using a fireplace that has been dormant or worked on.`},
  {q:`What does the $199 service include?`,a:`Full chimney sweep from firebox to pot, flue clean, soot and creosote removal, blockage and bird nest check, verbal condition report. No call-out fee — $199 per chimney.`},
  {q:`Our South Yarra home has two fireplaces — can both be cleaned in one visit?`,a:`Yes. Multi-fireplace visits are straightforward — just let us know the number of chimneys when you book so we can allow the right amount of time.`},
  {q:`Is there a call-out fee for South Yarra?`,a:`No — $199 flat rate per chimney, complete price.`}
];
---

<MainLayout
