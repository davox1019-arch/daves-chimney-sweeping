  description="Chimney sweeping South Yarra VIC 3141 — $199 chimney inspection & full clean. Daves Chimney Sweeping: flue cleaning, wood heater service. Call 0476 302 729."
  clusterBase="Melbourne's Inner Eastern Suburbs"
  clusterRegion="Melbourne's inner eastern suburbs"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Chimney Sweep South Yarra 3141</h1>
      <p class="hero-sub">$199 chimney inspection &amp; full clean &mdash; South Yarra &amp; surrounds. Owner-operated, no call-out fee, same-week bookings.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="tel:0476302729">Call 0476&nbsp;302&nbsp;729</a>
        <a class="btn-secondary" href="#booking">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <span>&#10003; $199 flat rate</span>
    <span>&#10003; No call-out fee</span>
    <span>&#10003; Same-week bookings</span>
    <span>&#10003; Owner-operated</span>
    <span>&#10003; South Yarra &amp; surrounds</span>
  </section>

  <!-- PRICING -->
