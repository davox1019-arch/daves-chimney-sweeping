---
import MainLayout from "../../layouts/MainLayout.astro";

const faqs = [
  {
    q: "Is Melton South the same postcode as Melton?",
    a: "No — Melton South has its own postcode, 3338. Melton itself is mostly 3337. We service both."
  },
  {
    q: "My chimney hasn't been cleaned in a few years — is that a problem?",
    a: "It depends on how much it's been used, but a few years without a clean usually means there's meaningful buildup. We'll assess it on the day and let you know what we find."
  },
  {
    q: "Do you clean wood heaters or just open fireplaces?",
    a: "Both. Wood heaters, slow combustion heaters and open fireplaces — we handle all of them, along with their flues."
  },
  {
    q: "How do I book?",
    a: "Just give us a call on 0476 302 729 or use the contact form. We'll sort out a time that works for you."
  }
];
---

<MainLayout
  title="Chimney Sweeping Melton South VIC 3338"
  description="Chimney sweeping in Melton South VIC 3338. Daves Chimney Sweeping offers flue cleaning, wood heater servicing and fireplace cleaning. Local, fast quotes."
  clusterBase="Melton"
  clusterRegion="Melton and surrounding suburbs"
  homeHref="/chimney-sweeping/melton"
  servicePageHref="/chimney-sweeping/melton"
  servicePageLabel="Melton Chimney Sweeping"
>
  <style>
    :root {
      --brand-dark: #1a1a18;
      --brand-mid: #2c2c29;
      --brand-accent: #c8500a;
      --brand-warm: #f5f0e8;
      --brand-white: #ffffff;
      --text-main: #1a1a18;
      --text-muted: #5a5a54;
      --border: #e2ddd4;
      --radius: 10px;
    }
    .hero { background: var(--brand-dark); color: var(--brand-white); padding: 2.8rem 1.25rem 2.5rem; text-align: center; }
    .hero-eyebrow { display: inline-block; background: var(--brand-accent); color: #fff; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.3rem 0.85rem; border-radius: 20px; margin-bottom: 1.1rem; }
    .hero h1 { font-size: clamp(1.65rem, 5vw, 2.2rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--brand-white); }
    .hero-lead { font-size: 1rem; line-height: 1.65; color: #c8c5be; margin: 0 auto 0.75rem; max-width: 480px; }
    .hero-sub { font-size: 0.93rem; line-height: 1.6; color: #908d86; max-width: 480px; margin: 0 auto 2rem; }
    .btn-row { display: flex; flex-direction: column; gap: 0.75rem; align-items: center; }
    .btn { display: inline-block; padding: 0.95rem 2rem; border-radius: var(--radius); font-size: 1rem; font-weight: 700; text-decoration: none; text-align: center; width: 100%; max-width: 320px; transition: opacity 0.15s; }
    .btn:hover { opacity: 0.88; }
    .btn-call { background: var(--brand-accent); color: #fff; font-size: 1.1rem; }
    .btn-quote { background: transparent; border: 2px solid #5a5a54; color: #c8c5be; }

    .trust-bar { background: var(--brand-mid); padding: 0.95rem 1.25rem; display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
    .trust-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: #908d86; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; }
    .trust-item svg { flex-shrink: 0; color: var(--brand-accent); }

    .section { padding: 2.2rem 1.25rem; max-width: 680px; margin: 0 auto; }
    .section + .section { border-top: 1px solid var(--border); }
    .section-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand-accent); margin-bottom: 0.55rem; }
    .section h2 { font-size: clamp(1.25rem, 4vw, 1.6rem); font-weight: 800; letter-spacing: -0.02em; color: var(--text-main); margin: 0 0 1rem; line-height: 1.25; }
    .section p { font-size: 0.97rem; line-height: 1.7; color: var(--text-muted); margin: 0 0 0.85rem; }
    .section p:last-child { margin-bottom: 0; }

    /* Numbered steps — unique to this page */
    .step-list { list-style: none; padding: 0; margin: 1.25rem 0 0; display: flex; flex-direction: column; gap: 1rem; }
    .step-item { display: flex; gap: 1rem; align-items: flex-start; }
    .step-num { flex-shrink: 0; width: 2rem; height: 2rem; background: var(--brand-accent); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800; }
    .step-text { font-size: 0.95rem; line-height: 1.6; color: var(--text-muted); padding-top: 0.2rem; }

    /* Included items — horizontal pill list */
    .included-list { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-top: 1.1rem; }
    .included-item { background: var(--brand-warm); border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.85rem; font-size: 0.84rem; font-weight: 600; color: var(--text-main); }

    .about-card { background: var(--brand-warm); border-radius: var(--radius); border: 1px solid var(--border); padding: 1.5rem 1.25rem; margin-top: 1rem; }
    .about-card p { font-size: 0.96rem; line-height: 1.7; color: var(--text-muted); margin: 0 0 0.8rem; }
    .about-detail { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--text-muted); margin-top: 0.5rem; }
    .about-detail strong { color: var(--text-main); }
    .about-detail a { color: var(--brand-accent); font-weight: 700; text-decoration: none; }

    .faq-list { display: flex; flex-direction: column; margin-top: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    details.faq-item { border-bottom: 1px solid var(--border); }
    details.faq-item:last-child { border-bottom: none; }
    details.faq-item summary { padding: 1rem 1.1rem; font-size: 0.95rem; font-weight: 700; color: var(--text-main); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; user-select: none; background: var(--brand-white); transition: background 0.15s; }
    details.faq-item summary::-webkit-details-marker { display: none; }
    details.faq-item summary:hover { background: var(--brand-warm); }
    details.faq-item summary::after { content: "+"; font-size: 1.3rem; font-weight: 400; color: var(--brand-accent); flex-shrink: 0; margin-left: 1rem; }
    details.faq-item[open] summary::after { content: "−"; }
    .faq-answer { padding: 0 1.1rem 1rem; font-size: 0.93rem; line-height: 1.7; color: var(--text-muted); background: var(--brand-white); }

    .suburb-chips { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-top: 1.1rem; }
    .suburb-chip { display: inline-block; background: var(--brand-warm); border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.85rem; font-size: 0.84rem; font-weight: 600; color: var(--text-main); text-decoration: none; transition: background 0.15s, border-color 0.15s; }
    .suburb-chip:hover { background: var(--brand-accent); border-color: var(--brand-accent); color: #fff; }

    .page-links { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.1rem; }
    .page-link { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; background: var(--brand-warm); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; font-size: 0.93rem; font-weight: 600; color: var(--text-main); transition: background 0.15s, border-color 0.15s; }
    .page-link:hover { background: var(--brand-accent); border-color: var(--brand-accent); color: #fff; }
    .page-link span { opacity: 0.5; font-size: 1.1rem; }

    .bottom-cta { background: var(--brand-dark); color: var(--brand-white); padding: 2.5rem 1.25rem; text-align: center; }
    .bottom-cta h2 { font-size: clamp(1.3rem, 4.5vw, 1.7rem); font-weight: 800; letter-spacing: -0.02em; color: var(--brand-white); margin: 0 0 0.6rem; }
    .bottom-cta p { font-size: 0.95rem; color: #908d86; margin: 0 0 1.75rem; line-height: 1.6; }
  </style>

  <section class="hero">
    <span class="hero-eyebrow">Melton South VIC 3338</span>
    <h1>Chimney Sweeping<br>Melton South VIC 3338</h1>
    <p class="hero-lead">
      Regular chimney and flue cleaning keeps your fireplace and wood heater working properly — and Melton South winters give them plenty of work to do.
    </p>
    <p class="hero-sub">
      Daves Chimney Sweeping provides straightforward, local chimney care for homes across Melton South 3338 and the surrounding area.
    </p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

  <div class="trust-bar">
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Melton South locals
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      All heater types
    </span>
    <span class="trust-item">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Fast, honest quotes
    </span>
  </div>

  <section class="section">
    <p class="section-label">Why it matters</p>
    <h2>Why Regular Chimney Cleaning Makes a Difference</h2>
    <p>
      Fireplaces and wood heaters that get regular use accumulate soot, ash and creosote in the flue over time. Left too long, that buildup can restrict airflow and cause the kinds of problems that bring most homeowners to us.
    </p>
    <ol class="step-list">
      <li class="step-item">
        <span class="step-num">1</span>
        <span class="step-text"><strong>Better draw</strong> — a clean flue pulls air through more effectively, making fires easier to start and maintain.</span>
      </li>
      <li class="step-item">
        <span class="step-num">2</span>
        <span class="step-text"><strong>No smoke back-up</strong> — blocked or dirty flues are the most common reason smoke drifts back into the room.</span>
      </li>
      <li class="step-item">
        <span class="step-num">3</span>
        <span class="step-text"><strong>Fewer smells</strong> — creosote and old ash are the main cause of persistent smoky odours around a fireplace.</span>
      </li>
      <li class="step-item">
        <span class="step-num">4</span>
        <span class="step-text"><strong>Long-term care</strong> — catching problems like nesting or cracks early keeps things running smoothly for longer.</span>
      </li>
    </ol>
  </section>

  <section class="section">
    <p class="section-label">What's included</p>
    <h2>Chimney &amp; Flue Services for Melton South Homes</h2>
    <p>
      We keep the service scope straightforward. Most Melton South jobs involve one or more of the following:
    </p>
    <div class="included-list">
      <span class="included-item">🔥 Chimney sweeping</span>
      <span class="included-item">🌬️ Flue cleaning</span>
      <span class="included-item">🪵 Wood heater service</span>
      <span class="included-item">🏠 Open fireplace clean</span>
      <span class="included-item">⬛ Soot &amp; ash removal</span>
      <span class="included-item">🐦 Blockage clearing</span>
    </div>
  </section>

  <section class="section">
    <p class="section-label">About us</p>
    <h2>Local Service, No Middleman</h2>
    <div class="about-card">
      <p>
        Daves Chimney Sweeping covers Melton South VIC 3338 and the broader Melton area. We're not a franchise — it's just Dave, doing the work himself, dealing with customers directly.
      </p>
      <p>
        That means no automated booking systems, no call centres, and no surprises on price. You speak to Dave, he sorts it out.
      </p>
      <div class="about-detail">📞 <strong>Phone:</strong>&nbsp;<a href="tel:0476302729">0476 302 729</a></div>
      <div class="about-detail">📍 <strong>Service area:</strong>&nbsp;Melton South VIC 3338 and surrounds</div>
    </div>
  </section>

  <section class="section">
    <p class="section-label">FAQs</p>
    <h2>Questions From Melton South Customers</h2>
    <div class="faq-list">
      {faqs.map(({ q, a }) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <div class="faq-answer">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="section">
    <p class="section-label">Nearby areas</p>
    <h2>Other Parts of the Melton Area We Cover</h2>
    <p>Melton South sits in the middle of the broader Melton cluster — here are the nearby suburbs we also service:</p>
    <div class="suburb-chips">
      <a class="suburb-chip" href="/chimney-sweeping/melton">Melton 3337</a>
      <a class="suburb-chip" href="/chimney-sweeping/melton-west">Melton West 3337</a>
      <a class="suburb-chip" href="/chimney-sweeping/brookfield">Brookfield 3338</a>
      <a class="suburb-chip" href="/chimney-sweeping/cobblebank">Cobblebank 3338</a>
      <a class="suburb-chip" href="/chimney-sweeping/kurunjang">Kurunjang 3337</a>
    </div>
  </section>

  <section class="section">
    <p class="section-label">More pages</p>
    <h2>Nearby Service Pages</h2>
    <nav class="page-links" aria-label="Nearby suburb pages">
      <a class="page-link" href="/chimney-sweeping/melton">Chimney Sweeping — Melton VIC 3337 <span>›</span></a>
      <a class="page-link" href="/chimney-sweeping/melton-west">Chimney Sweeping — Melton West VIC 3337 <span>›</span></a>
      <a class="page-link" href="/chimney-sweeping/brookfield">Chimney Sweeping — Brookfield VIC 3338 <span>›</span></a>
      <a class="page-link" href="/contact">Get a Quote <span>›</span></a>
    </nav>
  </section>

  <section class="bottom-cta">
    <h2>Time to Get the Flue Sorted in Melton South?</h2>
    <p>Give Dave a call or drop us a message — we'll get back to you with a no-nonsense quote.</p>
    <div class="btn-row">
      <a class="btn btn-call" href="tel:0476302729">📞 Call 0476 302 729</a>
      <a class="btn btn-quote" href="/contact">Request a Quote</a>
    </div>
  </section>

</MainLayout>
