---
import MainLayout from "../../layouts/MainLayout.astro";

const posts = [
  {
    slug: "prepare-fireplace-for-winter-melbourne",
    title: "How to Prepare Your Fireplace for Winter in Melbourne (2026 Checklist)",
    description: "April and May are the right time to get your fireplace or wood heater winter-ready. Here's the full checklist — before the cold hits.",
    readTime: "6 min",
    date: "April 2026",
  },
  {
    slug: "wood-heater-not-drawing-properly",
    title: "Wood Heater Not Drawing Properly? Here's Why (and How to Fix It)",
    description: "Poor draw is one of the most common wood heater problems. Most causes are straightforward — here's how to diagnose and fix it.",
    readTime: "6 min",
    date: "April 2026",
  },
  {
    slug: "is-it-safe-to-use-fireplace-without-cleaning",
    title: "Is It Safe to Use a Fireplace Without Cleaning It First?",
    description: "The honest answer depends on when it was last cleaned, what the buildup looks like, and whether there are any blockages.",
    readTime: "5 min",
    date: "April 2026",
  },
  {
    slug: "how-to-tell-chimney-needs-cleaning",
    title: "How to Tell If Your Chimney Needs Cleaning (7 Clear Signs)",
    description: "From obvious smoke problems to subtle signs most homeowners miss — here's how to tell if your chimney needs attention.",
    readTime: "5 min",
    date: "April 2026",
  },
  {
    slug: "chimney-sweep-cost-melbourne",
    title: "How Much Does Chimney Sweeping Cost in Melbourne?",
    description: "Typical Melbourne chimney sweep prices, what's included, and what the tiered pricing covers — no surprises.",
    readTime: "5 min",
    date: "April 2026",
  },
  {
    slug: "how-often-chimney-cleaning-melbourne",
    title: "How Often Should You Get Your Chimney Cleaned in Melbourne?",
    description: "The standard answer is once a year — but the right frequency depends on how often you use your fire and what you're burning.",
    readTime: "5 min",
    date: "April 2026",
  },
  {
    slug: "signs-chimney-needs-cleaning",
    title: "5 Warning Signs Your Chimney Needs Cleaning Right Now",
    description: "Smoke coming back in, a sluggish fire, a persistent burn smell — here's what your chimney is trying to tell you.",
    readTime: "4 min",
    date: "April 2026",
  },
  {
    slug: "what-happens-dont-clean-chimney",
    title: "What Happens If You Don't Clean Your Chimney?",
    description: "Skipping the annual clean feels like saving money — until creosote builds up, a chimney fire starts, or an insurance claim gets rejected.",
    readTime: "5 min",
    date: "April 2026",
  },
  {
    slug: "best-firewood-melbourne",
    title: "Best Firewood for Melbourne Winters (and What NOT to Burn)",
    description: "Red gum, ironbark, box — and why burning green wood or pine is costing you more than just money.",
    readTime: "5 min",
    date: "April 2026",
  },
  {
    slug: "when-book-chimney-sweep-melbourne",
    title: "When Is the Best Time to Book a Chimney Sweep in Melbourne?",
    description: "March to early May is the sweet spot — before the winter rush, before the waitlists, and before your first cold night.",
    readTime: "4 min",
    date: "April 2026",
  },
];
---

<MainLayout
  title="Chimney & Wood Heater Blog — Dave's Chimney Sweeping Melbourne"
  description="Practical advice on chimney cleaning, firewood, wood heater maintenance and fire safety for Melbourne homeowners."
  suppressAbout={true}
>
  <style>
    .blog-index-hero {
      background: linear-gradient(160deg, #2c1a0c 0%, #18120a 100%);
      color: white;
      padding: 56px 20px 48px;
      border-bottom: 3px solid #c8500a;
    }

    .blog-index-hero-inner {
      max-width: 860px;
      margin: 0 auto;
    }

    .blog-label {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #c8500a;
      margin-bottom: 14px;
    }

    .blog-index-hero h1 {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 800;
      margin: 0 0 14px;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    .blog-index-hero p {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.7);
      margin: 0;
      max-width: 520px;
    }

    .blog-index-body {
      max-width: 860px;
      margin: 0 auto;
      padding: 52px 20px 72px;
    }

    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 24px;
    }

    .blog-card {
      background: rgba(255,255,255,0.94);
      border: 1px solid #e5dbcf;
      border-radius: 18px;
      padding: 28px 26px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.06);
      display: flex;
      flex-direction: column;
      gap: 10px;
      transition: box-shadow 0.2s, transform 0.2s;
      text-decoration: none;
      color: inherit;
    }

    .blog-card:hover {
      box-shadow: 0 16px 40px rgba(0,0,0,0.1);
      transform: translateY(-2px);
    }

    .blog-card-meta {
      font-size: 0.78rem;
      color: #c8500a;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .blog-card h2 {
      font-size: 1.15rem;
      font-weight: 800;
      margin: 0;
      color: #171717;
      line-height: 1.3;
      letter-spacing: -0.01em;
    }

    .blog-card p {
      font-size: 0.95rem;
      line-height: 1.7;
      color: #555;
      margin: 0;
      flex: 1;
    }

    .blog-card-link {
      font-size: 0.9rem;
      font-weight: 700;
      color: #c8500a;
      margin-top: 4px;
    }

    @media (max-width: 600px) {
      .blog-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="blog-index-hero">
    <div class="blog-index-hero-inner">
      <span class="blog-label">Resources</span>
      <h1>Chimney & Wood Heater Advice</h1>
      <p>Practical guides for Melbourne homeowners with fireplaces, wood heaters and flues.</p>
    </div>
  </div>

  <div class="blog-index-body">
    <div class="blog-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="blog-card-meta">{post.date} &middot; {post.readTime} read</div>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
          <span class="blog-card-link">Read article →</span>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
